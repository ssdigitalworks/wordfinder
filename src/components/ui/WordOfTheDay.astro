---
const WORDS_OF_THE_DAY = [
  {
    word: 'QUIXOTIC',
    definition: 'Extremely idealistic, unrealistic, and impractical.',
    points: 26,
    tip: 'QUIXOTIC is a jackpot word. The Q and X are both high-value tiles. Look for opportunities to place Q on a Double Letter Score and X on a Triple Letter Score to easily score 60+ points.',
  },
  {
    word: 'MUZJIKS',
    definition: 'Russian peasants (plural of muzhik).',
    points: 29,
    tip: 'MUZJIKS contains two high-scoring Z and J tiles. This word is perfect when you have consonants clustered on your rack. Playing this on a Triple Word Score will easily win you the game.',
  },
  {
    word: 'HAZZANS',
    definition: 'Cantors in synagogues (plural of hazzan).',
    points: 28,
    tip: 'HAZZANS uses two Z tiles. If you are playing with blank tiles or have drawn both Zs, this is a spectacular play. Hooking it with an S at the end is a common way to seal a board lane.',
  },
  {
    word: 'OXYPHENBUTAZONE',
    definition: 'A non-steroidal anti-inflammatory drug.',
    points: 41,
    tip: 'While extremely rare, this is theoretically the highest-scoring single-word play in Scrabble history (hooked across three Triple Word Scores for 1,778 points!).',
  },
  {
    word: 'BEZIQUE',
    definition: 'A card game similar to pinochle.',
    points: 27,
    tip: 'BEZIQUE is an excellent way to get rid of Q and Z in a single turn. Since it uses common vowels (E, I, U), it is surprisingly easy to construct.',
  },
  {
    word: 'JEZEBEL',
    definition: 'A shameless, impudent, or abandoned woman.',
    points: 25,
    tip: 'JEZEBEL has a high concentration of J and Z. It is a 7-letter word, which makes it eligible for a Bingo bonus (+50 points) if you manage to play all tiles from your rack!',
  },
  {
    word: 'JAZZY',
    definition: 'Lively, active, or showy.',
    points: 33,
    tip: 'JAZZY is one of the highest-scoring 5-letter words. With two Zs and a J, placing this on a Double or Triple Word Score can easily yield massive points.',
  },
  {
    word: 'CAZIQUES',
    definition: 'Indian chiefs in Spanish America (plural of cazique).',
    points: 28,
    tip: 'CAZIQUES is a brilliant 8-letter play. If you can make a Bingo with this, including the Z and Q, you will score a minimum of 78 points, plus the 50-point bonus!',
  },
  {
    word: 'ZYMURGY',
    definition: 'The branch of chemistry dealing with fermentation processes.',
    points: 25,
    tip: 'ZYMURGY is a fantastic play when you have high-value consonants like Z, Y, and M. It does not require many vowels, making it a great rack-clearing option.',
  },
  {
    word: 'QOPH',
    definition: 'The nineteenth letter of the Hebrew alphabet.',
    points: 18,
    tip: 'QOPH is a life-saver when you are stuck with a Q but have no U. It is a short, easy-to-play 4-letter word that can be hooked onto existing letters easily.',
  },
  {
    word: 'XENON',
    definition: 'A heavy, colorless, odorless noble gas.',
    points: 12,
    tip: 'XENON is a neat, low-vowel way to deploy your X tile. Playing it horizontally or vertically across a Double or Triple Letter Score maximizes the 8 points from the X.',
  },
  {
    word: 'FYGHTING',
    definition: 'An archaic spelling of fighting.',
    points: 19,
    tip: 'FYGHTING uses the Y and G. High-value archaic spellings are legal in SOWPODS and can catch your opponent completely off-guard.',
  },
  {
    word: 'KLAXONS',
    definition: 'Loud electric horns (plural of klaxon).',
    points: 20,
    tip: 'KLAXONS combines K and X. Hooking it with an S at the end or placing the X on a premium square is an excellent way to secure a major lead.',
  },
  {
    word: 'MEZQUITS',
    definition: 'Spiny shrubs or trees of the southwestern US (plural of mezquit).',
    points: 28,
    tip: 'MEZQUITS is an 8-letter powerhouse. It uses Z and Q, which makes it extremely high-scoring. Perfect for late-game play when the board is crowded.',
  },
  {
    word: 'JUKEBOX',
    definition: 'A coin-operated phonograph.',
    points: 27,
    tip: 'JUKEBOX is a fantastic word containing both J and X. If you have a blank tile or a lucky draw, this is a premium play to close out a close game.',
  },
];

import { TWL_SCORES } from '../../data/tileScores';

const TILE_SCORES = TWL_SCORES;

// Fallback computed for initial server paint to avoid CLS
const dailyIndex = Math.floor(Date.now() / (24 * 60 * 60 * 1000));
const selected = WORDS_OF_THE_DAY[dailyIndex % WORDS_OF_THE_DAY.length];
---

<div
  class="card relative overflow-hidden flex flex-col justify-between h-full bg-[var(--color-card)] border border-[var(--color-border)] transition-all duration-300 hover:shadow-lg"
>
  <!-- Dynamic blur aura backdrop -->
  <div
    class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-[var(--color-primary)]/10 blur-xl pointer-events-none"
  >
  </div>

  <div>
    <div class="flex items-center justify-between mb-4">
      <span
        class="text-xs font-bold text-[var(--color-primary)] uppercase tracking-widest flex items-center gap-1.5"
      >
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-[var(--color-primary)] animate-ping"
        ></span>
        Word of the Day
      </span>
      <span class="score-badge text-xs px-2 py-0.5" id="wotd-points">{selected.points} pts</span>
    </div>

    <!-- 3D Tiles rendering -->
    <div
      class="flex flex-wrap gap-1.5 mb-5 justify-center py-2 bg-[var(--color-bg-alt)]/50 rounded-xl border border-[var(--color-border)]/50"
      id="wotd-tiles"
    >
      {
        selected.word.split('').map((ch) => (
          <span class="tile !w-9 !h-9 !text-base shadow-sm">
            {ch}
            <sub class="!text-[0.55rem]">{TILE_SCORES[ch] || 0}</sub>
          </span>
        ))
      }
    </div>

    <div class="space-y-2.5">
      <h3
        class="font-['Plus_Jakarta_Sans',system-ui,sans-serif] font-bold text-lg text-[var(--color-text-main)]"
        id="wotd-word"
      >
        {selected.word}
      </h3>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
        <strong>Definition:</strong>
        <span id="wotd-definition">{selected.definition}</span>
      </p>
      <div class="p-3.5 bg-[var(--color-bg-alt)] border border-[var(--color-border)] rounded-xl">
        <p class="text-xs font-semibold text-[var(--color-text-main)] mb-1 flex items-center gap-1">
          💡 Pro-Tip
        </p>
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed" id="wotd-tip">
          {selected.tip}
        </p>
      </div>
    </div>
  </div>

  <div class="mt-5 pt-3 border-t border-[var(--color-border)] flex items-center justify-between">
    <a
      href={`/dictionary-checker?word=${selected.word.toLowerCase()}`}
      id="wotd-lookup-link"
      class="text-xs font-semibold text-[var(--color-primary)] hover:underline flex items-center gap-1"
    >
      Lookup Definition →
    </a>
    <button
      type="button"
      class="text-xs font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-text-main)] transition-colors share-word-btn"
      id="wotd-copy-btn"
      data-word={selected.word}
    >
      Copy Word
    </button>
  </div>
</div>

<script is:inline define:vars={{ WORDS_OF_THE_DAY, TILE_SCORES }}>
  (function () {
    const dailyIndex = Math.floor(Date.now() / (24 * 60 * 60 * 1000));
    const selected = WORDS_OF_THE_DAY[dailyIndex % WORDS_OF_THE_DAY.length];

    const pointsEl = document.getElementById('wotd-points');
    const tilesEl = document.getElementById('wotd-tiles');
    const wordEl = document.getElementById('wotd-word');
    const defEl = document.getElementById('wotd-definition');
    const tipEl = document.getElementById('wotd-tip');
    const linkEl = document.getElementById('wotd-lookup-link');
    const copyBtn = document.getElementById('wotd-copy-btn');

    if (pointsEl) pointsEl.textContent = `${selected.points} pts`;
    if (wordEl) wordEl.textContent = selected.word;
    if (defEl) defEl.textContent = selected.definition;
    if (tipEl) tipEl.textContent = selected.tip;
    if (linkEl) linkEl.href = `/dictionary-checker?word=${selected.word.toLowerCase()}`;
    if (copyBtn) {
      copyBtn.dataset.word = selected.word;
    }

    if (tilesEl) {
      tilesEl.innerHTML = selected.word
        .split('')
        .map((ch) => {
          const score = TILE_SCORES[ch] || 0;
          return `<span class="tile !w-9 !h-9 !text-base shadow-sm">${ch}<sub class="!text-[0.55rem]">${score}</sub></span>`;
        })
        .join('');
    }

    // Handle sharing copy action
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const word = copyBtn.dataset.word;
        if (!word) return;

        navigator.clipboard.writeText(word).then(() => {
          const originalText = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.add('text-[var(--color-primary)]');
          setTimeout(() => {
            copyBtn.textContent = originalText;
            copyBtn.classList.remove('text-[var(--color-primary)]');
          }, 1500);
        });
      });
    }
  })();
</script>
