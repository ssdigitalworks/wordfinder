---
interface Props {
  score: number;
  size?: 'sm' | 'md' | 'lg';
}

const { score, size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'text-xs px-2 py-0.5',
  md: 'text-sm px-3 py-1',
  lg: 'text-base px-4 py-1.5',
};
---

<span class={`score-badge ${sizeClasses[size]}`}>
  {score} pts
</span>
