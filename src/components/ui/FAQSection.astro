---
interface PropFAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: PropFAQ[];
  title?: string;
}

const { faqs, title = 'Frequently Asked Questions' } = Astro.props;
---

{
  faqs && faqs.length > 0 && (
    <div class="card p-6 md:p-8 border border-[var(--color-border)] bg-[var(--color-card)] mt-8">
      <h2 class="text-xl md:text-2xl font-bold mb-6 font-['Plus_Jakarta_Sans',system-ui,sans-serif] text-[var(--color-text-main)]">
        {title}
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group border-b border-[var(--color-border)] last:border-none pb-4 last:pb-0 cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-sm sm:text-base text-[var(--color-text-main)] list-none outline-none hover:text-[var(--color-primary)] transition-colors py-1">
              <span>{faq.question}</span>
              <span class="text-xs transition-transform group-open:rotate-180 text-[var(--color-text-muted)]">
                ▼
              </span>
            </summary>
            <div class="text-xs sm:text-sm text-[var(--color-text-muted)] leading-relaxed mt-2 pl-3 border-l-2 border-[var(--color-primary)]">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  )
}
