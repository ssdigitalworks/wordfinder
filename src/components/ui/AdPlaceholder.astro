---
import { getSettings } from '../../lib/getSetting';

interface Props {
  slot_id?: string;
  size?: 'leaderboard' | 'rectangle' | 'skyscraper' | 'responsive';
  class?: string;
  ad_type?: 'adsense' | 'html';
  html_code?: string;
}

const {
  slot_id,
  size = 'responsive',
  class: className = '',
  ad_type = 'adsense',
  html_code = '',
} = Astro.props;

// Fetch settings dynamically from database
const settingsObj = await getSettings({
  adsense_enabled: 'false',
  adsense_client_id: import.meta.env.PUBLIC_ADSENSE_CLIENT_ID || 'ca-pub-XXXXXXXXXXXXXXXX',
  adsense_sandbox_mode: 'true',
  adsense_excluded_paths: '/admin/*, /login, /404'
});

const adsenseEnabled = settingsObj.adsense_enabled === 'true';
const adsenseClientId = settingsObj.adsense_client_id;
const adsenseSandboxMode = settingsObj.adsense_sandbox_mode === 'true';

// Exclusions Path check
const currentPath = Astro.url.pathname;
const excludedPathsRaw = settingsObj.adsense_excluded_paths;
const excludedPaths = excludedPathsRaw
  .split(',')
  .map((p) => p.trim())
  .filter(Boolean);

let isPathExcluded = false;
for (const pattern of excludedPaths) {
  if (pattern.endsWith('*')) {
    const prefix = pattern.slice(0, -1);
    if (currentPath.startsWith(prefix)) {
      isPathExcluded = true;
      break;
    }
  } else if (currentPath === pattern) {
    isPathExcluded = true;
    break;
  }
}

const sizeClasses: Record<string, string> = {
  leaderboard: 'min-h-[90px] w-full max-w-[728px] overflow-hidden',
  rectangle: 'min-h-[250px] w-full max-w-[300px] overflow-hidden',
  skyscraper: 'min-h-[600px] w-full max-w-[160px] overflow-hidden',
  responsive: 'min-h-[90px] sm:min-h-[90px] w-full overflow-hidden',
};

// If monetization is globally disabled or path is excluded, render nothing
const shouldShowAd = adsenseEnabled && !isPathExcluded;
---

{
  shouldShowAd &&
    (ad_type === 'html' ? (
      adsenseSandboxMode ? (
        <div
          class={`ad-placeholder flex flex-col items-center justify-center border border-dashed border-[var(--color-border)] bg-[var(--color-bg-offset)]/40 rounded-xl px-4 py-3 mx-auto w-full ${sizeClasses[size]} ${className}`}
        >
          <span class="text-xs font-semibold text-[var(--color-text-muted)] tracking-wider uppercase mb-1 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
            Advertisement
          </span>
          <span class="text-[10px] text-[var(--color-text-muted)] opacity-60 font-[var(--font-control)]">
            Custom HTML Ad Placeholder ({size})
          </span>
        </div>
      ) : (
        <div class={`html-ad-block w-full mx-auto ${className}`}>
          <Fragment set:html={html_code} />
        </div>
      )
    ) : adsenseSandboxMode || adsenseClientId === 'ca-pub-XXXXXXXXXXXXXXXX' || !slot_id ? (
      <div
        class={`ad-placeholder flex flex-col items-center justify-center border border-dashed border-[var(--color-border)] bg-[var(--color-bg-offset)]/40 rounded-xl px-4 py-3 mx-auto w-full ${sizeClasses[size]} ${className}`}
      >
        <span class="text-xs font-semibold text-[var(--color-text-muted)] tracking-wider uppercase mb-1 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
          Advertisement
        </span>
        <span class="text-[10px] text-[var(--color-text-muted)] opacity-60 font-[var(--font-control)]">
          Google AdSense Placeholder ({size})
        </span>
      </div>
    ) : (
      <div class={`ad-slot ${sizeClasses[size]} w-full mx-auto ${className}`}>
        <ins
          class="adsbygoogle"
          style="display:block; text-align:center;"
          data-ad-client={adsenseClientId}
          data-ad-slot={slot_id}
          data-ad-format={size === 'responsive' ? 'auto' : undefined}
          data-full-width-responsive={size === 'responsive' ? 'true' : undefined}
        />
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
    ))
}
