---
interface WordEntry {
  word: string;
  score: number;
  definition?: string;
}

interface Props {
  words: WordEntry[];
  title?: string;
  showDefinition?: boolean;
  columns?: 2 | 3 | 4;
  linkPattern?: string;
}

const {
  words,
  title,
  showDefinition = false,
  columns = 3,
  linkPattern = '/dictionary-checker?word={word}',
} = Astro.props;

import { TWL_SCORES } from '../../data/tileScores';

const defaultScores = TWL_SCORES;

const colClasses: Record<number, string> = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};
---

{
  title && (
    <h3 class="font-['Plus_Jakarta_Sans',system-ui,sans-serif] text-lg font-bold text-[var(--color-text-main)] mb-4">
      {title}
    </h3>
  )
}

<div class={`grid ${colClasses[columns]} gap-2`}>
  {
    words.map((entry) => {
      const letters = entry.word.toUpperCase().split('');
      const wordHref = linkPattern.replace('{word}', entry.word.toLowerCase());
      return (
        <a
          href={wordHref}
          class="flex items-center justify-between gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] px-3 py-2.5 hover:border-[var(--color-primary-light)] hover:shadow-sm transition-all duration-200 group"
        >
          <div class="flex items-center gap-1 flex-wrap min-w-0">
            {letters.map((letter) => {
              const tileScore = defaultScores[letter] ?? 0;
              return (
                <span class="tile !w-7 !h-7 !text-xs">
                  {letter}
                  <sub>{tileScore}</sub>
                </span>
              );
            })}
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="score-badge text-xs px-2 py-0.5">{entry.score} pts</span>
            <svg aria-hidden="true" focusable="false" class="h-3.5 w-3.5 text-gray-300 group-hover:text-[var(--color-primary)] transition-colors"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </div>
        </a>
      );
    })
  }
</div>

{
  showDefinition && words.some((w) => w.definition) && (
    <div class="mt-6 space-y-3">
      {words
        .filter((w) => w.definition)
        .map((entry) => (
          <div class="flex gap-3 text-sm">
            <span class="font-mono font-bold text-[var(--color-primary)] uppercase shrink-0">
              {entry.word}
            </span>
            <span class="text-[var(--color-text-muted)]">{entry.definition}</span>
          </div>
        ))}
    </div>
  )
}
