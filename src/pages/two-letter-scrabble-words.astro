---
import { SITE_URL } from '@lib/config';
import { TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES } from '../data/tileScores';
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import { loadDictionary } from '../lib/dictionaryLoader';
import { calculateWordScore } from '../lib/scoreCalculator';

const title = 'Two Letter Scrabble Words — Complete Official List';
const description =
  'Complete list of all valid 2-letter words in Scrabble. Essential for parallel plays, hooks, and tight board positions. Includes scores for TWL, SOWPODS, and ENABLE.';

const twlWords = [...(await loadDictionary('TWL'))].filter((w) => w.length === 2);
const sowpodsWords = [...(await loadDictionary('SOWPODS'))].filter((w) => w.length === 2);
const enableWords = [...(await loadDictionary('ENABLE'))].filter((w) => w.length === 2);

// Group by starting letter
function groupByFirst(words: string[]) {
  const groups: Record<string, { word: string; score: number }[]> = {};
  words.forEach((w) => {
    const first = w[0].toUpperCase();
    if (!groups[first]) groups[first] = [];
    groups[first].push({ word: w.toUpperCase(), score: calculateWordScore(w, 'TWL') });
  });
  // Sort each group
  Object.values(groups).forEach((arr) => arr.sort((a, b) => a.word.localeCompare(b.word)));
  return groups;
}

const twlGrouped = groupByFirst(twlWords);
const sowpodsGrouped = groupByFirst(sowpodsWords);
const enableGrouped = groupByFirst(enableWords);

const allGroupedJson = JSON.stringify({
  TWL: twlGrouped,
  SOWPODS: sowpodsGrouped,
  ENABLE: enableGrouped,
});
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Word Lists', href: '/word-lists' },
  { label: '2-Letter Words' },
];
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    canonical=`${SITE_URL}/two-letter-scrabble-words`
    schemaType="List"
    listItems={twlWords.map((w) => ({ name: w, url: `/word/${w.toLowerCase()}` }))}
  />

  <Breadcrumb items={breadcrumbItems} />

  <section class="py-10 md:py-16">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-3">
          Two Letter Scrabble Words
        </h1>
        <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto">
          The complete list of valid 2-letter words — a must-know for competitive play. Master these
          to dominate the board.
        </p>
      </div>

      <!-- Dictionary Filter -->
      <div class="flex justify-center gap-2 mb-8">
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-primary)] text-white"
          data-dict="TWL">TWL</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)]"
          data-dict="SOWPODS">SOWPODS</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)]"
          data-dict="ENABLE">ENABLE</button
        >
      </div>

      <div class="flex gap-6">
        <!-- Alphabet Sidebar -->
        <nav
          class="hidden md:flex flex-col gap-1 sticky top-24 self-start"
          aria-label="Alphabet navigation"
        >
          {
            alphabet.map((letter) => (
              <a
                href={`#letter-${letter}`}
                class="w-8 h-8 flex items-center justify-center text-sm font-semibold rounded hover:bg-[var(--color-primary)] hover:text-white transition-colors text-[var(--color-text-muted)]"
              >
                {letter}
              </a>
            ))
          }
        </nav>

        <!-- Word Grid -->
        <div id="word-grid" class="flex-1">
          {
            alphabet.map((letter) => (
              <div id={`letter-${letter}`} class="mb-8 scroll-mt-20">
                <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                  <span class="w-9 h-9 flex items-center justify-center bg-[var(--color-primary)] text-white rounded-lg font-bold">
                    {letter}
                  </span>
                  <span>Words starting with {letter}</span>
                </h2>
                <div
                  class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 letter-group"
                  data-letter={letter}
                >
                  {(twlGrouped[letter] || []).map(({ word, score }) => (
                    <a
                      href={`/word/${word.toLowerCase()}`}
                      class="word-card bg-[var(--color-card)] rounded-lg border border-[var(--color-border)] p-3 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all cursor-pointer block"
                      data-word={word}
                    >
                      <div class="flex items-center justify-center gap-0.5 mb-1">
                        {word.split('').map((ch) => (
                          <span class="tile tile-sm">
                            {ch}
                            <sub>{calculateWordScore(ch, 'TWL')}</sub>
                          </span>
                        ))}
                      </div>
                      <span class="score-badge text-xs">{score} pts</span>
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Mobile alphabet bar -->
      <div
        class="md:hidden fixed bottom-0 left-0 right-0 bg-[var(--color-card)] border-t border-[var(--color-border)] px-2 py-1.5 flex justify-between z-40"
      >
        {
          alphabet.map((letter) => (
            <a
              href={`#letter-${letter}`}
              class="text-[10px] font-bold text-[var(--color-text-muted)] hover:text-[var(--color-primary)]"
            >
              {letter}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 max-w-4xl">
    <AdPlaceholder slot_id="two-letter-mid" class="my-8" />
  </div>

  <!-- SEO Content -->
  <section class="py-12 md:py-16 border-t">
    <div class="container mx-auto px-4 max-w-4xl prose prose-lg">
      <h2 class="text-2xl font-bold mb-4">Why Two-Letter Words Matter in Scrabble</h2>
      <p>
        Two-letter words are the building blocks of competitive Scrabble. They allow you to make
        parallel plays — placing tiles alongside existing words to score points for multiple
        two-letter combinations simultaneously. A single play can create 3-4 two-letter words at
        once, dramatically multiplying your score.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4">How Many 2-Letter Words Are There?</h2>
      <p>
        The TWL dictionary contains <strong>{twlWords.length}</strong> valid two-letter words, while SOWPODS
        contains
        <strong>{sowpodsWords.length}</strong>. The ENABLE dictionary (Words With Friends) accepts <strong
          >{enableWords.length}</strong
        >
        two-letter words. Memorizing all of them gives you a significant advantage.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4">Key Two-Letter Words to Remember</h2>
      <ul>
        <li>
          <strong>QI</strong> — The most important Q word, playable without U (worth 11 points)
        </li>
        <li><strong>ZA</strong> — Short for pizza, the highest-scoring common 2-letter word</li>
        <li><strong>XI</strong> — Greek letter, great for the X tile</li>
        <li><strong>JO</strong> — Scottish term for sweetheart, uses the J tile effectively</li>
        <li><strong>KA</strong> — Egyptian spiritual concept, good for the K tile</li>
      </ul>

      <h2 class="text-2xl font-bold mt-10 mb-4">Related Word Lists</h2>
      <div class="not-prose grid grid-cols-2 md:grid-cols-3 gap-4">
        <a
          href="/3-letter-words"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all transition-shadow"
        >
          <span class="text-xl font-bold text-[var(--color-primary)]">3-Letter Words</span>
        </a>
        <a
          href="/words-without-vowels"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all transition-shadow"
        >
          <span class="text-xl font-bold text-[var(--color-primary)]">No-Vowel Words</span>
        </a>
        <a
          href="/word-list"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all transition-shadow"
        >
          <span class="text-xl font-bold text-[var(--color-primary)]">All Lists</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ allGroupedJson, TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES }}>
  (function () {
    const allGrouped = JSON.parse(allGroupedJson);
    const TILE_SCORES = {
      TWL: TWL_SCORES,
      SOWPODS: SOWPODS_SCORES,
      ENABLE: ENABLE_SCORES,
    };

    let currentDict = 'TWL';

    function renderGroup(dict) {
      const data = allGrouped[dict] || {};
      const scores = TILE_SCORES[dict];
      document.querySelectorAll('.letter-group').forEach((group) => {
        const letter = group.dataset.letter;
        const words = data[letter] || [];
        if (!words.length) {
          group.innerHTML =
            '<p class="text-[var(--color-text-muted)] text-sm col-span-full">No words</p>';
          return;
        }
        group.innerHTML = words
          .map(({ word }) => {
            const score = word.split('').reduce((t, c) => t + (scores[c] || 0), 0);
            return `<a href="/word/${word.toLowerCase()}" class="word-card bg-[var(--color-card)] rounded-lg border border-[var(--color-border)] p-3 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all cursor-pointer block" data-word="${word}">
          <div class="flex items-center justify-center gap-0.5 mb-1">${word
            .split('')
            .map((c) => `<span class="tile tile-sm">${c}<sub>${scores[c] || 0}</sub></span>`)
            .join('')}</div>
          <span class="score-badge text-xs">${score} pts</span>
        </a>`;
          })
          .join('');
      });
    }

    document.querySelectorAll('.dict-filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.dict-filter-btn').forEach((b) => {
          b.classList.remove('bg-[var(--color-primary)]', 'text-white');
          b.classList.add('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        });
        btn.classList.add('bg-[var(--color-primary)]', 'text-white');
        btn.classList.remove('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        currentDict = btn.dataset.dict;
        renderGroup(currentDict);
      });
    });
  })();
</script>
