---
import { SITE_URL } from '@lib/config';
import { getSetting } from '@lib/getSetting';
import BaseLayout from '@layouts/BaseLayout.astro';
import SEO from '@components/seo/SEO.astro';
import Breadcrumb from '@components/layout/Breadcrumb.astro';

export const prerender = false;

const dbContactEmail = await getSetting('contact_email', 'hello@scrabblewordfinder.com');
const dbContactResponse = await getSetting(
  'contact_response_time',
  'We typically respond within 24–48 hours.',
);
const dbContactTitle = await getSetting('contact_title', 'Contact Us — Scrabble Word Finder');
const dbContactDesc = await getSetting(
  'contact_description',
  'Get in touch with the Scrabble Word Finder team. Send us feedback, report a bug, suggest a feature, or just say hello.',
);
const contactFormEnabled = (await getSetting('contact_form_enabled', 'true')) !== 'false';
const contactSuccessMessage = await getSetting(
  'contact_success_message',
  'Thank you for reaching out. We have received your message and will get back to you as soon as possible.',
);
const contactSubjectsRaw = await getSetting(
  'contact_subjects',
  'General Inquiry, Bug Report, Feature Request, Feedback, Other',
);
const contactSubjects = contactSubjectsRaw
  .split(',')
  .map((s) => s.trim())
  .filter((s) => s.length > 0);

const canonical = new URL(Astro.url.pathname, SITE_URL).href;
---

<BaseLayout>
  <SEO slot="head" title={dbContactTitle} description={dbContactDesc} canonical={canonical} />

  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Contact Us' }]} />

  <section class="max-w-3xl mx-auto px-4 py-12">
    <!-- Page Header -->
    <div class="text-center mb-10">
      <h1
        class="text-4xl md:text-5xl font-extrabold text-[var(--color-text-main)] mb-4 font-['Plus_Jakarta_Sans',system-ui,sans-serif] animate-entrance"
      >
        Contact Us
      </h1>
      <p
        class="text-lg text-[var(--color-text-muted)] max-w-xl mx-auto leading-relaxed animate-entrance delay-1"
      >
        {dbContactDesc}
      </p>
    </div>

    <!-- Contact Form Container -->
    <div
      id="contact-container"
      data-success-message={contactSuccessMessage}
      class="card p-8 md:p-10 animate-entrance delay-2"
    >
      {
        !contactFormEnabled ? (
          <div class="text-center py-10">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-yellow-50 text-yellow-600 dark:bg-yellow-950/20 dark:text-yellow-400 border border-yellow-200 dark:border-yellow-900/30 mb-4 text-2xl font-bold">
              ⚠️
            </div>
            <h3 class="text-xl font-bold text-[var(--color-text-main)] mb-2 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
              Contact Form Offline
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] max-w-md mx-auto leading-relaxed">
              Our online contact form is temporarily offline. Please reach out to us directly via
              our support email listed below.
            </p>
          </div>
        ) : (
          <form id="contact-form" class="space-y-6">
            {/* Name Field */}
            <div class="space-y-2">
              <label for="name" class="block text-sm font-semibold text-[var(--color-text-main)]">
                Your Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Jane Doe"
                class="input-field"
              />
            </div>

            {/* Email Field */}
            <div class="space-y-2">
              <label for="email" class="block text-sm font-semibold text-[var(--color-text-main)]">
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="jane@example.com"
                class="input-field"
              />
            </div>

            {/* Subject Field */}
            <div class="space-y-2">
              <label
                for="subject"
                class="block text-sm font-semibold text-[var(--color-text-main)]"
              >
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                class="input-field appearance-none bg-no-repeat bg-[right_1rem_center]"
                style="background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 fill=%22none%22 viewBox=%220 0 20 20%22%3E%3Cpath stroke=%22%236b7280%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22 stroke-width=%221.5%22 d=%22m6 8 4 4 4-4%22/%3E%3C/svg%3E');"
              >
                {contactSubjects.map((subj) => (
                  <option value={subj.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>{subj}</option>
                ))}
              </select>
            </div>

            {/* Message Field */}
            <div class="space-y-2">
              <label
                for="message"
                class="block text-sm font-semibold text-[var(--color-text-main)]"
              >
                Message
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us what's on your mind..."
                class="input-field resize-y min-h-[120px]"
              />
            </div>

            {/* Honeypot Field */}
            <div class="h-0 w-0 overflow-hidden pointer-events-none opacity-0" aria-hidden="true">
              <label for="website_url">Website URL</label>
              <input
                type="text"
                id="website_url"
                name="website_url"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            {/* Submit Button */}
            <button type="submit" class="w-full btn-primary">
              {' '}
              Send Message{' '}
            </button>
          </form>
        )
      }

      <!-- Direct Email Note -->
      <div
        class="mt-6 border border-[var(--color-border)] rounded-xl p-4 bg-[var(--color-bg-offset)]/30"
      >
        <p class="text-sm text-[var(--color-text-muted)] flex items-start gap-2">
          <span class="mt-0.5">📧</span>
          <span>
            Prefer direct email? You can also reach us at
            <a
              href={`mailto:${dbContactEmail}`}
              class="text-[var(--color-primary)] font-semibold hover:underline">{dbContactEmail}</a
            >.
          </span>
        </p>
      </div>
    </div>

    <!-- Additional Info -->
    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6 animate-entrance delay-3">
      <div class="card p-6 text-center">
        <div class="text-3xl mb-3">📧</div>
        <h2
          class="font-bold text-[var(--color-text-main)] mb-1 font-['Plus_Jakarta_Sans',system-ui,sans-serif]"
        >
          Email
        </h2>
        <a
          href={`mailto:${dbContactEmail}`}
          class="text-[var(--color-primary)] hover:underline text-sm font-medium"
        >
          {dbContactEmail}
        </a>
      </div>
      <div class="card p-6 text-center">
        <div class="text-3xl mb-3">⏱️</div>
        <h2
          class="font-bold text-[var(--color-text-main)] mb-1 font-['Plus_Jakarta_Sans',system-ui,sans-serif]"
        >
          Response Time
        </h2>
        <p class="text-sm text-[var(--color-text-muted)]">
          {dbContactResponse}
        </p>
      </div>
    </div>
  </section>

  <script>
    import { showToast } from '../lib/toast';

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const container = document.getElementById('contact-container') as HTMLDivElement | null;
    const successMsgText =
      container?.getAttribute('data-success-message') ||
      'Thank you for reaching out. We have received your message.';

    if (form && container) {
      form.setAttribute('novalidate', 'true');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (!submitBtn) return;

        const nameInput = document.getElementById('name') as HTMLInputElement | null;
        const emailInput = document.getElementById('email') as HTMLInputElement | null;
        const subjectInput = document.getElementById('subject') as HTMLSelectElement | null;
        const messageInput = document.getElementById('message') as HTMLTextAreaElement | null;
        const honeypotInput = document.getElementById('website_url') as HTMLInputElement | null;

        if (!nameInput || !emailInput || !subjectInput || !messageInput) return;

        let hasError = false;
        [nameInput, emailInput, messageInput].forEach((input) => {
          if (!input.value.trim()) {
            input.classList.add('border-red-500');
            hasError = true;
          } else {
            input.classList.remove('border-red-500');
          }
        });

        if (emailInput.value && !emailInput.value.includes('@')) {
          emailInput.classList.add('border-red-500');
          hasError = true;
        }

        if (hasError) return;

        // Set loading state
        const originalBtnText = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
          <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Sending...
        `;

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              name: nameInput.value,
              email: emailInput.value,
              subject: subjectInput.value,
              message: messageInput.value,
              website_url: honeypotInput?.value || '',
            }),
          });

          const data = await response.json();

          if (response.ok) {
            container.innerHTML = `
              <div class="text-center py-12 px-4 animate-entrance">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 mb-6 text-3xl font-bold">
                  ✓
                </div>
                <h3 class="text-2xl font-bold text-[var(--color-text-main)] mb-3 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
                  Message Sent Successfully!
                </h3>
                <p class="text-[var(--color-text-muted)] max-w-md mx-auto mb-8 leading-relaxed">
                  ${successMsgText}
                </p>
                <button id="reload-btn" class="btn-primary inline-flex items-center gap-2">
                  Send Another Message
                </button>
              </div>
            `;

            const reloadBtn = document.getElementById('reload-btn');
            if (reloadBtn) {
              reloadBtn.addEventListener('click', () => {
                window.location.reload();
              });
            }
          } else {
            throw new Error(data.error || 'Something went wrong');
          }
        } catch (error: unknown) {
          showToast((error as Error).message || 'Failed to send message. Please try again.', 'error');
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
      });

      const inputs = form.querySelectorAll('input, textarea, select');
      inputs.forEach((input) => {
        input.addEventListener('input', () => {
          input.classList.remove('border-red-500');
        });
      });
    }
  </script>
</BaseLayout>
