---
import { SITE_URL } from '@lib/config';
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/seo/SEO.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import { loadDictionary } from '../../lib/dictionaryLoader';
import { calculateWordScore } from '../../lib/scoreCalculator';

export async function getStaticPaths() {
  const letters = 'abcdefghijklmnopqrstuvwxyz'.split('');
  return letters.map((letter) => ({
    params: { letter },
    props: { letter: letter.toUpperCase() },
  }));
}

const { letter } = Astro.props;
const dict = await loadDictionary('TWL');
const words = [...dict]
  .filter((w) => w.length === 3 && w.includes(letter))
  .map((w) => ({ word: w, score: calculateWordScore(w, 'TWL') }))
  .sort((a, b) => b.score - a.score);

const allLetters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const title = `3 Letter Words With ${letter} — Scrabble Word List`;
const description = `All 3-letter Scrabble words containing ${letter}. ${words.length} valid words with scores.`;
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    canonical={new URL(`/3-letter-words-with/${letter.toLowerCase()}`, SITE_URL).href}
  />

  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumb
      items={[
        { label: 'Word Lists', href: '/word-list' },
        { label: '3-Letter Words', href: '/3-letter-words' },
        { label: `With ${letter}` },
      ]}
    />

    <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text-main)] mb-2">
      3 Letter Words With {letter}
    </h1>
    <p class="text-[var(--color-text-muted)] mb-6">
      Found <strong class="text-[var(--color-primary)]">{words.length}</strong> three-letter words containing
      {letter}.
    </p>

    <div class="flex flex-wrap gap-1.5 mb-8">
      {
        allLetters.map((l) => (
          <a
            href={`/3-letter-words-with/${l.toLowerCase()}`}
            class={`w-9 h-9 flex items-center justify-center rounded-lg text-sm font-semibold transition-all duration-200 ${
              l === letter
                ? 'bg-[var(--color-primary)] text-white shadow-md'
                : 'bg-[var(--color-card)] border border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]'
            }`}
          >
            {l}
          </a>
        ))
      }
    </div>

    {
      words.length > 0 ? (
        <div class="bg-[var(--color-card)] rounded-2xl border border-[var(--color-border)] shadow-sm p-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-1">
            {words.map(({ word, score }) => (
              <a
                href={`/word/${word.toLowerCase()}`}
                class="word-result-row hover:bg-[var(--color-bg-alt)] transition-all block"
                style="text-decoration: none;"
              >
                <div class="flex items-center gap-1">
                  {word.split('').map((ch) => (
                    <span class="tile">
                      {ch}
                      <sub>
                        {{
                          A: 1,
                          B: 3,
                          C: 3,
                          D: 2,
                          E: 1,
                          F: 4,
                          G: 2,
                          H: 4,
                          I: 1,
                          J: 8,
                          K: 5,
                          L: 1,
                          M: 3,
                          N: 1,
                          O: 1,
                          P: 3,
                          Q: 10,
                          R: 1,
                          S: 1,
                          T: 1,
                          U: 1,
                          V: 4,
                          W: 4,
                          X: 8,
                          Y: 4,
                          Z: 10,
                        }[ch] || 0}
                      </sub>
                    </span>
                  ))}
                </div>
                <span class="score-badge">{score} pts</span>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center py-12 bg-[var(--color-card)] rounded-2xl border border-[var(--color-border)]">
          <p class="text-[var(--color-text-muted)]">No 3-letter words with {letter} found.</p>
        </div>
      )
    }

    <div class="mt-12">
      <h2 class="text-2xl font-bold mb-4">About 3-Letter Words Containing {letter}</h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed">
        Three-letter words are essential in Scrabble for parallel plays, hooks, and rack management.
        Knowing all the 3-letter words containing {letter} helps you spot scoring opportunities that other
        players miss.
      </p>
    </div>
  </div>
</BaseLayout>
