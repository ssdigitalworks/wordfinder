---
import { SITE_URL } from '@lib/config';
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';

const title = 'Page Not Found (404) — Scrabble Word Finder';
const description =
  'The page you are looking for does not exist. Use our Scrabble Word Finder to search for anagrams, solve word games, and find high-scoring words.';
const canonical = `${SITE_URL}/404`;
---

<BaseLayout>
  <SEO slot="head" title={title} description={description} canonical={canonical} noindex={true} />

  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Page Not Found' }]} />

  <section class="max-w-xl mx-auto px-4 py-20 text-center animate-entrance">
    <div class="mb-8">
      <div
        class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-[var(--color-primary-wash)] text-[var(--color-primary)] font-extrabold text-4xl mb-6 font-['Plus_Jakarta_Sans',system-ui,sans-serif]"
      >
        404
      </div>
      <h1
        class="text-3xl md:text-4xl font-extrabold text-[var(--color-text-main)] mb-4 font-['Plus_Jakarta_Sans',system-ui,sans-serif]"
      >
        Page Not Found
      </h1>
      <p class="text-base text-[var(--color-text-muted)] leading-relaxed mb-8">
        Sorry, we couldn't find the page you're looking for. It might have been moved, deleted, or
        the link you followed may be broken.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="btn-primary inline-flex items-center justify-center text-sm font-semibold px-6 py-3 rounded-xl shadow-sm"
      >
        Go to Homepage
      </a>
      <a
        href="/word-lists"
        class="btn-secondary inline-flex items-center justify-center text-sm font-medium px-6 py-3 rounded-xl border border-[var(--color-border)] hover:bg-[var(--color-bg-alt)] transition-colors"
      >
        Browse Word Lists
      </a>
    </div>
  </section>
</BaseLayout>
