<script>
  // Handle favoriting copy / toggle action
  const favBtn = document.getElementById('favorite-btn');
  if (favBtn) {
    const word = favBtn.dataset.word;

    // Check if already favorited on load
    const favorites = JSON.parse(localStorage.getItem('scrabble_favorites') || '[]');
    if (favorites.includes(word)) {
      if (favBtn) favBtn.textContent = '❤️';
      if (favBtn) favBtn.classList.add('text-red-500');
    } else {
      if (favBtn) favBtn.textContent = '🤍';
    }

    // Long Press / Hold gesture implementation
    let timer: ReturnType<typeof setTimeout> | null = null;
    let isLongPress = false;
    let ignoreNextClick = false;

    function triggerToggle() {
      if (!favBtn) return;
      favBtn.classList.remove('animate-heart-pop');
      void favBtn.offsetWidth; // force reflow
      favBtn.classList.add('animate-heart-pop');

      const currentFavs = JSON.parse(localStorage.getItem('scrabble_favorites') || '[]');
      const idx = currentFavs.indexOf(word);
      if (idx === -1) {
        currentFavs.push(word);
        favBtn.textContent = '❤️';
        favBtn.classList.add('text-red-500');

        if (typeof (window as any).animateFavoriteHeart === 'function') {
          (window as any).animateFavoriteHeart(favBtn);
        }
      } else {
        currentFavs.splice(idx, 1);
        favBtn.textContent = '🤍';
        favBtn.classList.remove('text-red-500');
      }
      localStorage.setItem('scrabble_favorites', JSON.stringify(currentFavs));
      // Dispatch custom event to notify other components (e.g. UserDashboard)
      window.dispatchEvent(new Event('scrabble_favorites_changed'));
    }

    function startPress(e: Event) {
      if (e.type === 'touchstart') {
        e.preventDefault();
      } else if (e.type === 'mousedown' && (e as MouseEvent).button !== 0) {
        return;
      }
      e.stopPropagation();
      isLongPress = false;
      if (favBtn) favBtn.classList.add('heart-grow');

      timer = setTimeout(() => {
        isLongPress = true;
        ignoreNextClick = true;
        if (favBtn) favBtn.classList.remove('heart-grow');
        triggerToggle();
        if ('vibrate' in navigator) {
          navigator.vibrate(40);
        }
      }, 600); // 600ms hold time
    }

    function endPress(e: Event) {
      if (e.type === 'touchend') {
        e.preventDefault();
      }
      e.stopPropagation();

      if (timer) {
        clearTimeout(timer);
        timer = null;
      }
      if (favBtn) favBtn.classList.remove('heart-grow');

      if (!isLongPress) {
        if (e.type === 'touchend') {
          triggerToggle();
        }
      }
    }

    function cancelPress(e: Event) {
      e.stopPropagation();
      if (timer) {
        clearTimeout(timer);
        timer = null;
      }
      if (favBtn) favBtn.classList.remove('heart-grow');
    }

    if (favBtn) {
      favBtn.addEventListener('mousedown', startPress);
      favBtn.addEventListener('mouseup', endPress);
      favBtn.addEventListener('mouseleave', cancelPress);

      favBtn.addEventListener('touchstart', startPress, { passive: false });
      favBtn.addEventListener('touchend', endPress, { passive: false });
      favBtn.addEventListener('touchcancel', cancelPress);

      favBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        if (ignoreNextClick) {
          ignoreNextClick = false;
          return;
        }
        triggerToggle();
      });

      favBtn.addEventListener('animationend', () => {
        if (favBtn) favBtn.classList.remove('animate-heart-pop');
      });
    }
  }
</script>
