---
import { SITE_URL } from '@lib/config';
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/seo/SEO.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import AdPlaceholder from '../../components/ui/AdPlaceholder.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import { loadDictionaryData } from '../../lib/dictionaryLoader';
import { calculateWordScore } from '../../lib/scoreCalculator';
import { getDynamicSEOStats } from '../../lib/wordStatsGenerator';
import DynamicSEOParagraph from '../../components/seo/DynamicSEOParagraph.astro';

// Deterministic pages can be cached heavily. Let's cache for 1 day at edge CDNs.
Astro.response.headers.set('Cache-Control', 'public, s-maxage=86400, stale-while-revalidate=3600');

const { pattern } = Astro.params;
if (!pattern) {
  return Astro.redirect('/word-lists');
}

const cleanedPattern = pattern.toUpperCase().replace(/[^A-Z]/g, '');
if (cleanedPattern.length === 0) {
  return Astro.redirect('/word-lists');
}

const dictParam = Astro.url.searchParams.get('dict')?.toUpperCase() || 'TWL';
const currentDict = ['TWL', 'SOWPODS', 'ENABLE'].includes(dictParam)
  ? (dictParam as 'TWL' | 'SOWPODS' | 'ENABLE')
  : 'TWL';

const dictData = await loadDictionaryData(currentDict);
const allWords = dictData.wordList.filter((w) => w.startsWith(cleanedPattern));

// Sort all matches by score descending, then alphabetical
allWords.sort((a, b) => {
  const scoreA = calculateWordScore(a, currentDict);
  const scoreB = calculateWordScore(b, currentDict);
  return scoreB - scoreA || a.localeCompare(b);
});

const pageParam = Astro.url.searchParams.get('page') || '1';
let page = parseInt(pageParam, 10);
if (isNaN(page) || page < 1) page = 1;

const totalMatches = allWords.length;
const totalPages = Math.ceil(totalMatches / 100);

const listStats = getDynamicSEOStats(allWords, currentDict);

if (page > totalPages && totalPages > 0) page = totalPages;

const pageWords = allWords.slice((page - 1) * 100, page * 100);
const pageWordsWithScores = pageWords.map((w) => ({
  word: w,
  score: calculateWordScore(w, currentDict),
}));

// Group pageWords by length
const groups: Record<number, { word: string; score: number }[]> = {};
pageWordsWithScores.forEach((w) => {
  const len = w.word.length;
  if (!groups[len]) groups[len] = [];
  groups[len].push(w);
});

const lengths = Object.keys(groups)
  .map(Number)
  .sort((a, b) => b - a);

const paginationSuffix = totalPages > 1 ? ` — Page ${page} of ${totalPages}` : '';
const title = `Words Starting With ${cleanedPattern}${paginationSuffix} — Scrabble Word Finder`;
const description = `Discover all valid Scrabble words starting with "${cleanedPattern}". Filter by TWL, SOWPODS, and ENABLE dictionaries with point scores and definitions.`;
const canonicalPageSuffix = page > 1 ? `?page=${page}` : '';
const canonical = `${SITE_URL}/words-starting-with/${cleanedPattern.toLowerCase()}${canonicalPageSuffix}`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Word Lists', href: '/word-lists' },
  { label: `Starting With ${cleanedPattern}` },
];

const top3Words = allWords
  .slice(0, 3)
  .map((w) => w)
  .join(', ');
const faqs = [
  {
    question: `How many Scrabble words start with the letters "${cleanedPattern}"?`,
    answer: `There are ${totalMatches} valid Scrabble words starting with the letters "${cleanedPattern}" in the ${currentDict} dictionary.`,
  },
  {
    question: `What are the highest scoring Scrabble words starting with "${cleanedPattern}"?`,
    answer: `Some of the highest scoring Scrabble words starting with "${cleanedPattern}" are ${top3Words || 'not available'}.`,
  },
  {
    question: `What is the longest word starting with the letters "${cleanedPattern}"?`,
    answer: `The longest words starting with the letters "${cleanedPattern}" in our list are ${lengths.length > 0 ? lengths[0] : 0}-letter words.`,
  },
];
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    canonical={canonical}
    schemaType="List"
    listItems={pageWords.slice(0, 50).map((w) => ({ name: w, url: `/word/${w.toLowerCase()}` }))}
    faqs={faqs}
  />
  {
    page > 1 && (
      <link
        slot="head"
        rel="prev"
        href={`${SITE_URL}/words-starting-with/${cleanedPattern.toLowerCase()}?page=${page - 1}`}
      />
    )
  }
  {
    page < totalPages && (
      <link
        slot="head"
        rel="next"
        href={`${SITE_URL}/words-starting-with/${cleanedPattern.toLowerCase()}?page=${page + 1}`}
      />
    )
  }

  <Breadcrumb items={breadcrumbItems} />

  <!-- Premium Blur Background Accent -->
  <div
    class="absolute top-0 left-0 w-full h-[650px] pointer-events-none overflow-hidden -z-10 opacity-75"
  >
    <div
      class="absolute top-[-12%] left-[10%] w-[40%] h-[55%] rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary-light)] blur-[100px] opacity-10 dark:opacity-[0.2] animate-pulse"
      style="animation-duration: 8s;"
    >
    </div>
  </div>

  <section class="py-10 md:py-16">
    <div class="container-narrow">
      <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl font-black mb-4 tracking-tight">
          Words Starting With <span class="text-[var(--color-primary)]">{cleanedPattern}</span>{paginationSuffix}
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
          Found <strong class="text-[var(--color-text-main)]">{totalMatches.toLocaleString()}</strong> Scrabble words starting with {cleanedPattern}.
        </p>
      </div>

      <DynamicSEOParagraph stats={listStats} type="Start" pattern={cleanedPattern} />

      <!-- Dictionary Filter Controls -->
      <div class="flex justify-center gap-2 mb-8">
        <a
          href={`/words-starting-with/${cleanedPattern.toLowerCase()}?dict=TWL`}
          class={`px-4 py-2 text-sm font-semibold rounded-full border transition-colors ${currentDict === 'TWL' ? 'bg-[var(--color-primary)] text-white border-[var(--color-primary)]' : 'bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] border-[var(--color-border)] hover:border-[var(--color-primary)] hover:text-[var(--color-text-main)]'}`}
          >TWL</a
        >
        <a
          href={`/words-starting-with/${cleanedPattern.toLowerCase()}?dict=SOWPODS`}
          class={`px-4 py-2 text-sm font-semibold rounded-full border transition-colors ${currentDict === 'SOWPODS' ? 'bg-[var(--color-primary)] text-white border-[var(--color-primary)]' : 'bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] border-[var(--color-border)] hover:border-[var(--color-primary)] hover:text-[var(--color-text-main)]'}`}
          >SOWPODS</a
        >
        <a
          href={`/words-starting-with/${cleanedPattern.toLowerCase()}?dict=ENABLE`}
          class={`px-4 py-2 text-sm font-semibold rounded-full border transition-colors ${currentDict === 'ENABLE' ? 'bg-[var(--color-primary)] text-white border-[var(--color-primary)]' : 'bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] border-[var(--color-border)] hover:border-[var(--color-primary)] hover:text-[var(--color-text-main)]'}`}
          >ENABLE</a
        >
      </div>

      <div class="flex gap-8">
        <!-- Length Navigation Sidebar -->
        <nav
          class="hidden md:flex flex-col gap-1 sticky top-24 self-start"
          aria-label="Lengths navigation"
          id="length-sidebar"
        >
          <span
            class="text-xs uppercase tracking-wider font-bold text-[var(--color-text-muted)] mb-2"
            >Lengths</span
          >
          {
            lengths.map((len) => (
              <a
                href={`#length-${len}`}
                class="w-10 h-10 flex items-center justify-center text-sm font-bold rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] hover:bg-[var(--color-primary)] hover:text-white transition-colors text-[var(--color-text-muted)] length-nav-link"
                data-length={len}
              >
                {len}
              </a>
            ))
          }
        </nav>

        <!-- Word Grid -->
        <div id="word-grid" class="flex-1">
          {
            lengths.map((len) => (
              <div id={`length-${len}`} class="mb-10 scroll-mt-20 length-block" data-length={len}>
                <h2 class="text-xl font-bold mb-4 flex items-center gap-2 border-b border-[var(--color-border)] pb-2 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
                  <span class="w-8 h-8 flex items-center justify-center bg-[var(--color-primary)] text-white rounded-lg font-bold text-sm">
                    {len}
                  </span>
                  <span>
                    {len}-Letter Words starting with {cleanedPattern}
                  </span>
                </h2>
                <div
                  class={
                    len >= 10
                      ? 'grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 letter-group'
                      : 'grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 letter-group'
                  }
                >
                  {(groups[len] || []).map(({ word: w, score }) => (
                    <a
                      href={`/word/${w.toLowerCase()}`}
                      class="word-card bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-3 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all cursor-pointer block"
                    >
                      <div class="flex items-center justify-center gap-0.5 mb-1.5">
                        {w.split('').map((ch) => (
                          <span class="tile tile-sm">
                            {ch}
                            <sub>{calculateWordScore(ch, currentDict)}</sub>
                          </span>
                        ))}
                      </div>
                      <span class="score-badge text-[10px]">{score} pts</span>
                    </a>
                  ))}
                </div>
              </div>
            ))
          }

          {
            totalMatches === 0 && (
              <div id="no-results-msg" class="text-center py-16 text-[var(--color-text-muted)]">
                <p class="text-lg font-medium">No words found in this dictionary</p>
              </div>
            )
          }

          {
            totalPages > 1 && (
              <nav
                class="flex items-center justify-between mt-10 border-t border-[var(--color-border)] pt-6"
                aria-label="Pagination"
              >
                <div>
                  {page > 1 ? (
                    <a
                      href={`/words-starting-with/${cleanedPattern.toLowerCase()}?dict=${currentDict}&page=${page - 1}`}
                      class="btn-ghost text-sm font-semibold"
                    >
                      ← Previous
                    </a>
                  ) : (
                    <span class="text-[var(--color-text-muted)] opacity-50 text-sm font-semibold">
                      ← Previous
                    </span>
                  )}
                </div>
                <span class="text-sm text-[var(--color-text-muted)]">
                  Page <strong>{page}</strong> of <strong>{totalPages}</strong>
                </span>
                <div>
                  {page < totalPages ? (
                    <a
                      href={`/words-starting-with/${cleanedPattern.toLowerCase()}?dict=${currentDict}&page=${page + 1}`}
                      class="btn-ghost text-sm font-semibold"
                    >
                      Next →
                    </a>
                  ) : (
                    <span class="text-[var(--color-text-muted)] opacity-50 text-sm font-semibold">
                      Next →
                    </span>
                  )}
                </div>
              </nav>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 max-w-4xl">
    <AdPlaceholder slot_id="pattern-page-mid" class="my-8" />
  </div>

  <!-- Rich Internal Linking Hub -->
  <section class="py-12 border-t border-[var(--color-border)] mt-12 bg-[var(--color-bg-alt)]/25">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Related Patterns -->
        <div class="card p-6 border border-[var(--color-border)] bg-[var(--color-card)]">
          <h3
            class="font-bold text-lg mb-3 font-['Plus_Jakarta_Sans',system-ui,sans-serif] text-[var(--color-text-main)]"
          >
            🔜 Related Word Beginnings
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              ['re', 'un', 'pre', 'de', 'di', 'con', 'in', 'ex', 'pro', 'ad', 'sub'].map((p) => (
                <a
                  href={`/words-starting-with/${p}`}
                  class="text-xs px-2.5 py-1.5 rounded-lg bg-[var(--color-bg-alt)] border border-[var(--color-border)] hover:border-[var(--color-primary)] text-[var(--color-text-main)] transition-colors"
                >
                  Starting with {p}-
                </a>
              ))
            }
          </div>
        </div>

        <!-- Related Word Lists -->
        <div class="card p-6 border border-[var(--color-border)] bg-[var(--color-card)]">
          <h3
            class="font-bold text-lg mb-3 font-['Plus_Jakarta_Sans',system-ui,sans-serif] text-[var(--color-text-main)]"
          >
            📋 Popular Word Lists
          </h3>
          <div class="flex flex-col gap-2 text-sm">
            <a
              href="/two-letter-scrabble-words"
              class="hover:text-[var(--color-primary)] transition-colors">2-Letter Words</a
            >
            <a href="/3-letter-words" class="hover:text-[var(--color-primary)] transition-colors"
              >3-Letter Words</a
            >
            <a
              href="/words-without-vowels"
              class="hover:text-[var(--color-primary)] transition-colors">Words Without Vowels</a
            >
            <a
              href="/scrabble-vowel-words"
              class="hover:text-[var(--color-primary)] transition-colors">Vowel-Heavy Words</a
            >
            <a
              href="/highest-scoring-scrabble-words"
              class="hover:text-[var(--color-primary)] transition-colors">Highest Scoring Words</a
            >
            <a href="/rare-q-words" class="hover:text-[var(--color-primary)] transition-colors"
              >Q Without U Words</a
            >
            <a href="/z-words-without-u" class="hover:text-[var(--color-primary)] transition-colors"
              >Z Without U Words</a
            >
          </div>
        </div>

        <!-- Related Tools -->
        <div class="card p-6 border border-[var(--color-border)] bg-[var(--color-card)]">
          <h3
            class="font-bold text-lg mb-3 font-['Plus_Jakarta_Sans',system-ui,sans-serif] text-[var(--color-text-main)]"
          >
            🛠️ Scrabble Help Tools
          </h3>
          <div class="flex flex-col gap-2 text-sm">
            <a href="/" class="hover:text-[var(--color-primary)] transition-colors"
              >Scrabble Word Finder</a
            >
            <a
              href="/dictionary-checker"
              class="hover:text-[var(--color-primary)] transition-colors">Dictionary Checker</a
            >
            <a href="/anagram-solver" class="hover:text-[var(--color-primary)] transition-colors"
              >Anagram Solver</a
            >
            <a href="/unscramble-words" class="hover:text-[var(--color-primary)] transition-colors"
              >Word Unscrambler</a
            >
            <a href="/crossword-solver" class="hover:text-[var(--color-primary)] transition-colors"
              >Crossword Solver</a
            >
            <a href="/wordle-solver" class="hover:text-[var(--color-primary)] transition-colors"
              >Wordle Solver</a
            >
            <a
              href="/words-with-friends-cheat"
              class="hover:text-[var(--color-primary)] transition-colors"
              >Words With Friends Cheat</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Word Lists Panel -->
  <div class="container mx-auto px-4 max-w-5xl mb-8 pt-8 border-t border-[var(--color-border)]">
    <h3 class="text-lg font-bold text-[var(--color-text-main)] mb-4">Related Word Lists</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      <a
        href={`/words-ending-in/${cleanedPattern.toLowerCase()}`}
        class="text-sm text-[var(--color-primary)] hover:underline"
      >
        Words Ending with {cleanedPattern}
      </a>
      <a
        href={`/words-containing-${cleanedPattern.toLowerCase()}`}
        class="text-sm text-[var(--color-primary)] hover:underline"
      >
        Words Containing {cleanedPattern}
      </a>
      {
        cleanedPattern.length === 1 && (
          <>
            <a
              href={`/2-letter-words-starting-with/${cleanedPattern.toLowerCase()}`}
              class="text-sm text-[var(--color-primary)] hover:underline"
            >
              2-Letter Words Starting with {cleanedPattern}
            </a>
            <a
              href={`/3-letter-words-starting-with/${cleanedPattern.toLowerCase()}`}
              class="text-sm text-[var(--color-primary)] hover:underline"
            >
              3-Letter Words Starting with {cleanedPattern}
            </a>
            <a
              href={`/4-letter-words-starting-with/${cleanedPattern.toLowerCase()}`}
              class="text-sm text-[var(--color-primary)] hover:underline"
            >
              4-Letter Words Starting with {cleanedPattern}
            </a>
            <a
              href={`/5-letter-words-starting-with/${cleanedPattern.toLowerCase()}`}
              class="text-sm text-[var(--color-primary)] hover:underline"
            >
              5-Letter Words Starting with {cleanedPattern}
            </a>
          </>
        )
      }
    </div>
  </div>

  <FAQSection faqs={faqs} />
</BaseLayout>
