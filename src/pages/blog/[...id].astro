---
import { SITE_URL } from '@lib/config';
export const prerender = false;

import BlogLayout from '../../layouts/BlogLayout.astro';
import { db } from '@db/client';
import { posts } from '@db/schema';
import { eq } from 'drizzle-orm';
import { marked } from 'marked';
import { getSetting } from '../../lib/getSetting';
import sanitizeHtml from 'sanitize-html';
import { parseTags, type BlogPost } from '../../lib/blog';

const { id: slug } = Astro.params;

let post: BlogPost | null = null;
let dbError = false;

if (db) {
  try {
    post = await db
      .select()
      .from(posts)
      .where(eq(posts.slug, slug || ''))
      .get() || null;
  } catch (e) {
    dbError = true;
    console.error('Error fetching post:', e);
  }
} else {
  dbError = true;
}



if (!post || !post.published || new Date(post.pubDate) > new Date()) {
  return Astro.redirect('/404');
}

// Render Markdown to HTML
const contentHtml = await marked.parse(post.content || '');
const sanitizedContent = sanitizeHtml(contentHtml, {
  allowedTags: sanitizeHtml.defaults.allowedTags.concat(['img', 'span', 'div']),
  allowedAttributes: {
    ...sanitizeHtml.defaults.allowedAttributes,
    '*': ['class', 'id'],
    img: ['src', 'alt', 'title', 'width', 'height', 'loading'],
    a: ['href', 'name', 'target', 'rel'],
  },
});

// Get related posts (same tags, excluding current)
let relatedPosts: Partial<BlogPost>[] = [];
let postTags: string[] = parseTags(post.tags);

let allPublished: Partial<BlogPost>[] = [];
if (db && !dbError) {
  try {
    allPublished = await db.select().from(posts).where(eq(posts.published, true)).all();
  } catch (e) {
    console.error('Error fetching related posts:', e);
  }
}



relatedPosts = allPublished
  .filter(
    (p) =>
      p.slug !== post?.slug &&
      (function () {
        const pTags = parseTags(p.tags);
        return pTags.some((t: string) => postTags.includes(t));
      })(),
  )
  .slice(0, 3)
  .map((p) => ({
    title: p.title,
    slug: p.slug,
    date: p.pubDate,
  }));
// Calculate dynamic reading time
const wordCount = (post.content || '')
  .trim()
  .split(/\s+/)
  .filter((w: string) => w.length > 0).length;
const readingTime = `${Math.ceil(wordCount / 200)} min read`;

// Dynamic In-Content Ad Insertion
const adsenseEnabled = (await getSetting('adsense_enabled', 'false')) === 'true';
const adsenseClientId = await getSetting(
  'adsense_client_id',
  import.meta.env.PUBLIC_ADSENSE_CLIENT_ID || 'ca-pub-XXXXXXXXXXXXXXXX',
);
const adsenseSandboxMode = (await getSetting('adsense_sandbox_mode', 'true')) === 'true';

const inContentAdEnabled = (await getSetting('adsense_in_content_ad_enabled', 'false')) === 'true';
const inContentAdSlot = await getSetting('adsense_in_content_ad_slot', '');
const inContentAdType = await getSetting('adsense_in_content_ad_type', 'adsense');
const inContentAdHtml = await getSetting('adsense_in_content_ad_html', '');
const inContentParagraphs =
  parseInt(await getSetting('adsense_in_content_paragraphs', '3'), 10) || 3;

// Exclusions Path check
const currentPath = Astro.url.pathname;
const excludedPathsRaw = await getSetting('adsense_excluded_paths', '/admin/*, /login, /404');
const excludedPaths = excludedPathsRaw
  .split(',')
  .map((p) => p.trim())
  .filter(Boolean);

let isPathExcluded = false;
for (const pattern of excludedPaths) {
  if (pattern.endsWith('*')) {
    const prefix = pattern.slice(0, -1);
    if (currentPath.startsWith(prefix)) {
      isPathExcluded = true;
      break;
    }
  } else if (currentPath === pattern) {
    isPathExcluded = true;
    break;
  }
}

const shouldShowAdsGlobal = adsenseEnabled && !isPathExcluded;

let finalContentHtml = sanitizedContent;
if (shouldShowAdsGlobal && inContentAdEnabled && (inContentAdType === 'html' || inContentAdSlot)) {
  const parts = sanitizedContent.split('</p>');
  let adHtml = '';

  if (inContentAdType === 'html') {
    adHtml = adsenseSandboxMode
      ? `<div class="ad-placeholder flex flex-col items-center justify-center border border-dashed border-[var(--color-border)] bg-[var(--color-bg-offset)]/40 rounded-xl px-4 py-3 mx-auto w-full h-[90px] sm:h-[90px] my-6 select-none">
          <span class="text-xs font-semibold text-[var(--color-text-muted)] tracking-wider uppercase mb-1 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">Advertisement</span>
          <span class="text-[10px] text-[var(--color-text-muted)] opacity-60 font-[var(--font-control)]">Custom HTML Ad Placeholder</span>
        </div>`
      : `<div class="html-ad-block w-full mx-auto my-6">${inContentAdHtml}</div>`;
  } else {
    adHtml =
      adsenseSandboxMode || adsenseClientId === 'ca-pub-XXXXXXXXXXXXXXXX' || !inContentAdSlot
        ? `<div class="ad-placeholder flex flex-col items-center justify-center border border-dashed border-[var(--color-border)] bg-[var(--color-bg-offset)]/40 rounded-xl px-4 py-3 mx-auto w-full h-[90px] sm:h-[90px] my-6 select-none">
          <span class="text-xs font-semibold text-[var(--color-text-muted)] tracking-wider uppercase mb-1 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">Advertisement</span>
          <span class="text-[10px] text-[var(--color-text-muted)] opacity-60 font-[var(--font-control)]">Google AdSense Placeholder (responsive)</span>
        </div>`
        : `<div class="ad-slot h-[90px] sm:h-[90px] w-full mx-auto my-6">
          <ins class="adsbygoogle" style="display:block; text-align:center;" data-ad-client="${adsenseClientId}" data-ad-slot="${inContentAdSlot}" data-ad-format="auto" data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>`;
  }

  if (parts.length > inContentParagraphs) {
    parts[inContentParagraphs - 1] = parts[inContentParagraphs - 1] + `</p>${adHtml}`;
    finalContentHtml = parts.join('</p>');
  } else {
    finalContentHtml = contentHtml + adHtml;
  }
}
---

<BlogLayout
  title={post.seoTitle || post.title}
  description={post.seoDescription || post.description}
  canonical={post.canonicalUrl || new URL(`/blog/${post.slug}`, SITE_URL).href}
  ogImage={post.image || undefined}
  publishedDate={post.pubDate}
  modifiedDate={post.updatedAt}
  author={post.author}
  tags={postTags}
  readingTime={readingTime}
  relatedPosts={relatedPosts.map(p => ({ title: p.title || '', slug: p.slug || '', date: p.pubDate || '' }))}
>
  <div set:html={finalContentHtml} />
</BlogLayout>
