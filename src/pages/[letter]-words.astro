---
import { SITE_URL } from '@lib/config';
import { TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES } from '../data/tileScores';
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import { loadDictionaryData } from '../lib/dictionaryLoader';
import { calculateWordScore } from '../lib/scoreCalculator';
import { getDynamicSEOStats } from '../lib/wordStatsGenerator';
import DynamicSEOParagraph from '../components/seo/DynamicSEOParagraph.astro';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=86400, stale-while-revalidate=86400');

const { letter } = Astro.params;

if (!letter || letter.length !== 1) {
  return Astro.redirect('/word-lists');
}

const cleanedLetter = letter.toUpperCase();
if (!/^[A-Z]$/.test(cleanedLetter)) {
  return Astro.redirect('/word-lists');
}

const twlDictData = await loadDictionaryData('TWL');
const sowpodsDictData = await loadDictionaryData('SOWPODS');
const enableDictData = await loadDictionaryData('ENABLE');

const twlWords = twlDictData.wordsByStartLetter[cleanedLetter] || [];
const sowpodsWords = sowpodsDictData.wordsByStartLetter[cleanedLetter] || [];
const enableWords = enableDictData.wordsByStartLetter[cleanedLetter] || [];

function getGroupedByLength(words: string[], dict: 'TWL' | 'SOWPODS' | 'ENABLE') {
  const groups: Record<number, { word: string; score: number }[]> = {};
  words.forEach((w) => {
    const len = w.length;
    if (!groups[len]) groups[len] = [];
    groups[len].push({ word: w, score: calculateWordScore(w, dict) });
  });
  Object.keys(groups).forEach((len) => {
    groups[Number(len)].sort((a, b) => b.score - a.score || a.word.localeCompare(b.word));
  });
  return groups;
}

const twlGrouped = getGroupedByLength(twlWords, 'TWL');
const sowpodsGrouped = getGroupedByLength(sowpodsWords, 'SOWPODS');
const enableGrouped = getGroupedByLength(enableWords, 'ENABLE');
const totalMatches = twlWords.length;

const listStats = getDynamicSEOStats(twlWords, 'TWL');

const allGroupedJson = JSON.stringify({
  TWL: twlGrouped,
  SOWPODS: sowpodsGrouped,
  ENABLE: enableGrouped,
});

const lengths = Array.from(
  new Set([
    ...Object.keys(twlGrouped).map(Number),
    ...Object.keys(sowpodsGrouped).map(Number),
    ...Object.keys(enableGrouped).map(Number),
  ]),
).sort((a, b) => b - a);

const title = `Scrabble Words Starting With ${cleanedLetter} — Complete List`;
const description = `Complete list of all valid Scrabble words starting with letter "${cleanedLetter}". Filter by TWL, SOWPODS, and ENABLE dictionaries with point values and definitions.`;
const canonical = new URL(`/${letter.toLowerCase()}-words`, SITE_URL).href;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Word Lists', href: '/word-lists' },
  { label: `${cleanedLetter} Words` },
];
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    canonical={canonical}
    schemaType="List"
    listItems={twlWords.slice(0, 50).map((w) => ({ name: w, url: `/word/${w.toLowerCase()}` }))}
  />

  <Breadcrumb items={breadcrumbItems} />

  {/* Premium Blur Background Accent */}
  <div
    class="absolute top-0 left-0 w-full h-[650px] pointer-events-none overflow-hidden -z-10 opacity-75"
  >
    <div
      class="absolute top-[-12%] left-[10%] w-[40%] h-[55%] rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary-light)] blur-[100px] opacity-10 dark:opacity-[0.2] animate-pulse"
      style="animation-duration: 8s;"
    >
    </div>
  </div>

  <section class="py-10 md:py-16">
    <div class="container-narrow">
      <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl font-black mb-4 tracking-tight">
          Scrabble Words Starting With <span class="text-[var(--color-primary)]">{cleanedLetter}</span>
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
          Found <strong class="text-[var(--color-text-main)]">{totalMatches.toLocaleString()}</strong> Scrabble words starting with {cleanedLetter}.
        </p>
      </div>
      
      <DynamicSEOParagraph stats={listStats} type="Start" pattern={cleanedLetter} />

      {/* Dictionary Filter Controls */}
      <div class="flex justify-center gap-2 mb-8">
        <button
          class="dict-filter-btn active px-4 py-2 text-sm font-semibold rounded-full bg-[var(--color-primary)] text-white"
          data-dict="TWL"
        >
          TWL
        </button>
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-semibold rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)] transition-colors border border-[var(--color-border)]"
          data-dict="SOWPODS"
        >
          SOWPODS
        </button>
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-semibold rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)] transition-colors border border-[var(--color-border)]"
          data-dict="ENABLE"
        >
          ENABLE
        </button>
      </div>

      <div class="flex gap-8">
        {/* Length Navigation Sidebar */}
        <nav
          class="hidden md:flex flex-col gap-1 sticky top-24 self-start"
          aria-label="Lengths navigation"
          id="length-sidebar"
        >
          <span
            class="text-xs uppercase tracking-wider font-bold text-[var(--color-text-muted)] mb-2"
          >
            Lengths
          </span>
          {
            lengths.map((len) => (
              <a
                href={`#length-${len}`}
                class="w-10 h-10 flex items-center justify-center text-sm font-bold rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] hover:bg-[var(--color-primary)] hover:text-white transition-colors text-[var(--color-text-muted)] length-nav-link"
                data-length={len}
              >
                {len}
              </a>
            ))
          }
        </nav>

        {/* Word List Grid */}
        <div id="word-grid" class="flex-1">
          {
            lengths.map((len) => (
              <div id={`length-${len}`} class="mb-10 scroll-mt-20 length-block" data-length={len}>
                <h2 class="text-xl font-bold mb-4 flex items-center gap-2 border-b border-[var(--color-border)] pb-2 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
                  <span class="w-8 h-8 flex items-center justify-center bg-[var(--color-primary)] text-white rounded-lg font-bold text-sm">
                    {len}
                  </span>
                  <span>
                    {len}-Letter Words starting with {cleanedLetter}
                  </span>
                </h2>
                  <div class={`grid gap-3 lg:gap-4 letter-group ${
                    len >= 11 ? 'grid-cols-1 md:grid-cols-2' :
                    len >= 8 ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' :
                    len >= 5 ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4' :
                    'grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5'
                  }`}>
                    {(twlGrouped[len] || []).map(({ word: w, score }) => (
                      <a
                        href={`/word/${w.toLowerCase()}`}
                        class="word-card bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-3 sm:p-4 text-center hover:shadow-lg hover:border-[var(--color-primary)] transition-all cursor-pointer block group"
                        data-word={w}
                      >
                        <div class="flex flex-wrap items-center justify-center gap-1 sm:gap-1.5 mb-2 sm:mb-3">
                          {w.split('').map((ch) => (
                            <span class="tile tile-sm group-hover:scale-105 transition-transform duration-200">
                              {ch}
                              <sub>{calculateWordScore(ch, 'TWL')}</sub>
                            </span>
                          ))}
                        </div>
                        <span class="score-badge text-xs sm:text-sm font-extrabold text-[var(--color-primary)] bg-[var(--color-primary-wash)] px-3 py-1 rounded-full inline-block">{score} pts</span>
                      </a>
                    ))}
                  </div>
              </div>
            ))
          }

          <div id="no-results-msg" class="hidden text-center py-16 text-[var(--color-text-muted)]">
            <p class="text-lg font-medium">No words found in this dictionary</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 max-w-4xl">
    <AdPlaceholder slot_id="pattern-page-mid" class="my-8" />

    <!-- Related Word Lists Panel -->
    <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
      <h3 class="text-lg font-bold text-[var(--color-text-main)] mb-4">Related Word Lists</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a
          href={`/words-starting-with/${cleanedLetter.toLowerCase()}`}
          class="text-sm text-[var(--color-primary)] hover:underline"
        >
          Words Starting with {cleanedLetter}
        </a>
        <a
          href={`/words-ending-in/${cleanedLetter.toLowerCase()}`}
          class="text-sm text-[var(--color-primary)] hover:underline"
        >
          Words Ending with {cleanedLetter}
        </a>
        <a
          href={`/two-letter-scrabble-words`}
          class="text-sm text-[var(--color-primary)] hover:underline"
        >
          2-Letter Words
        </a>
        <a href={`/3-letter-words`} class="text-sm text-[var(--color-primary)] hover:underline">
          3-Letter Words
        </a>
        <a href={`/4-letter-words`} class="text-sm text-[var(--color-primary)] hover:underline">
          4-Letter Words
        </a>
        <a href={`/5-letter-words`} class="text-sm text-[var(--color-primary)] hover:underline">
          5-Letter Words
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ allGroupedJson, TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES }}>
  (function () {
    const allGrouped = JSON.parse(allGroupedJson);
    const TILE_SCORES = {
      TWL: TWL_SCORES,
      SOWPODS: SOWPODS_SCORES,
      ENABLE: ENABLE_SCORES,
    };

    let currentDict = 'TWL';

    function renderGroup(dict) {
      const data = allGrouped[dict] || {};
      const scores = TILE_SCORES[dict];
      let totalCount = 0;

      const blocks = document.querySelectorAll('.length-block');
      blocks.forEach((block) => {
        const key = block.dataset.length;
        const words = data[key] || [];
        const groupContainer = block.querySelector('.letter-group');

        if (!words.length) {
          block.classList.add('hidden');
          const sidebarLink = document.querySelector(`.length-nav-link[data-length="${key}"]`);
          if (sidebarLink) sidebarLink.classList.add('hidden');
        } else {
          block.classList.remove('hidden');
          const sidebarLink = document.querySelector(`.length-nav-link[data-length="${key}"]`);
          if (sidebarLink) sidebarLink.classList.remove('hidden');

          totalCount += words.length;

          groupContainer.innerHTML = words
            .map(({ word, score }) => {
              const tilesHtml = word
                .split('')
                .map((c) => `<span class="tile tile-sm">${c}<sub>${scores[c] || 0}</sub></span>`)
                .join('');
              return `<a href="/word/${word.toLowerCase()}" class="word-card bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-3 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all cursor-pointer block">
            <div class="flex items-center justify-center gap-0.5 mb-1.5 flex-wrap">${tilesHtml}</div>
            <span class="score-badge text-[10px]">${score} pts</span>
          </a>`;
            })
            .join('');
        }
      });

      const matchLabel = document.getElementById('match-count-label');
      if (matchLabel) matchLabel.textContent = totalCount;

      const noResults = document.getElementById('no-results-msg');
      if (noResults) {
        if (totalCount === 0) noResults.classList.remove('hidden');
        else noResults.classList.add('hidden');
      }
    }

    document.querySelectorAll('.dict-filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.dict-filter-btn').forEach((b) => {
          b.classList.remove('bg-[var(--color-primary)]', 'text-white', 'active');
          b.classList.add('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        });
        btn.classList.add('bg-[var(--color-primary)]', 'text-white', 'active');
        btn.classList.remove('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        currentDict = btn.dataset.dict;
        renderGroup(currentDict);
      });
    });
  })();
</script>
