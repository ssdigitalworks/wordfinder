---
import { SITE_URL } from '@lib/config';
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import WordFinderForm from '../components/ui/WordFinderForm.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import WordOfTheDay from '../components/ui/WordOfTheDay.astro';
import DailyChallenge from '../components/ui/DailyChallenge.astro';
import SmartScrabbleCoach from '../components/ui/SmartScrabbleCoach.astro';

// Set long CDN cache headers for optimal performance
Astro.response.headers.set('Cache-Control', 'public, s-maxage=86400, stale-while-revalidate=86400');

import { db } from '@db/client';
import { posts } from '@db/schema';
import { desc, eq } from 'drizzle-orm';

let latestPosts: (typeof posts.$inferSelect)[] = [];
if (db) {
  try {
    const allPublished = await db
      .select()
      .from(posts)
      .where(eq(posts.published, true))
      .orderBy(desc(posts.pubDate))
      .all();
    const now = new Date();
    latestPosts = allPublished.filter((p) => new Date(p.pubDate) <= now).slice(0, 2);
  } catch (e) {
    console.error('Error fetching latest posts for homepage:', e);
  }
}

const title = 'Scrabble Word Finder — Find High Scoring Words Instantly';
const description =
  'Use our free Scrabble Word Finder to unscramble letters and find all valid words. Get word scores, sort by points or length, and dominate your next game.';
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
---

<BaseLayout>
  <SEO slot="head" title={title} description={description} canonical={canonical} type="website" />
  <JsonLd
    slot="head"
    schema={{
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      '@id': `${SITE_URL}/#webapplication`,
      isPartOf: { '@id': `${SITE_URL}/#website` },
      name: 'Scrabble Word Finder',
      url: SITE_URL,
      description,
      applicationCategory: 'GameApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      browserRequirements: 'Requires JavaScript',
    }}
  />

  <!-- Premium Static Blur Background Accent -->
  <div
    class="absolute top-0 left-0 w-full h-[650px] pointer-events-none overflow-hidden -z-10 opacity-75"
  >
    <div
      class="absolute top-[-15%] left-[15%] w-[70%] h-[60%] rounded-full bg-gradient-to-br from-[var(--color-primary)]/15 via-purple-500/10 to-pink-500/5 blur-[120px] dark:opacity-[0.35]"
    >
    </div>
  </div>

  <!-- Hero Section -->
  <section class="pt-12 md:pt-16 pb-2 md:pb-4 relative">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center">
        <h1
          class="font-['Plus_Jakarta_Sans',system-ui,sans-serif] text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-4 leading-tight animate-entrance bg-gradient-to-r from-[var(--color-primary)] via-indigo-600 to-purple-600 dark:from-indigo-400 dark:via-purple-400 dark:to-pink-400 bg-clip-text text-transparent"
        >
          Scrabble Word Finder
        </h1>
        <p
          class="text-base md:text-lg text-[var(--color-text-muted)] mb-8 max-w-2xl mx-auto animate-entrance delay-1"
        >
          Enter your letters and discover every valid word — with scores, definitions, and smart
          sorting.
        </p>

        <div class="max-w-2xl mx-auto text-left animate-entrance delay-2">
          <WordFinderForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="pt-2 md:pt-4 pb-8 md:pb-12">
    <div class="container mx-auto px-4 max-w-4xl">
      <!-- Loading State (hidden by default) -->
      <div id="results-loading" class="hidden py-8 scroll-mt-24 w-full" aria-hidden="true">
        <div class="animate-pulse space-y-6 max-w-4xl mx-auto w-full">
          <!-- Skeleton Result Group -->
          <div class="space-y-4 w-full">
            <div class="h-6 bg-[var(--color-border)] rounded w-32 mb-4"></div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 w-full">
              <div class="h-12 bg-[var(--color-border)] rounded-xl w-full"></div>
              <div class="h-12 bg-[var(--color-border)] rounded-xl w-full"></div>
              <div class="h-12 bg-[var(--color-border)] rounded-xl w-full"></div>
              <div class="h-12 bg-[var(--color-border)] rounded-xl w-full"></div>
            </div>
          </div>
          <!-- Skeleton Result Group -->
          <div class="space-y-4 w-full pt-4">
            <div class="h-6 bg-[var(--color-border)] rounded w-24 mb-4"></div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 w-full">
              <div class="h-12 bg-[var(--color-border)] rounded-xl w-full"></div>
              <div class="h-12 bg-[var(--color-border)] rounded-xl w-full"></div>
            </div>
          </div>
        </div>
      </div>



      <div id="results-container" class="min-h-[120px] scroll-mt-24 w-full" aria-live="polite">
        <!-- Populated by client JS -->
        <div id="results-empty-state" class="text-center py-16 text-[var(--color-text-muted)]">
          <svg
            class="w-16 h-16 mx-auto mb-4 opacity-40"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
          >
          <p id="results-empty-title" class="text-lg font-medium">
            Enter your letters above to find words
          </p>
          <p id="results-empty-text" class="text-sm mt-1">
            Use <code
              class="bg-[var(--color-border)] text-[var(--color-text-muted)] px-1.5 py-0.5 rounded text-xs"
              >?</code
            > for blank tiles
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 max-w-4xl">
    <AdPlaceholder slot_id="home-below-results" class="my-8" />
  </div>

  <!-- Interactive Word Gaming Dashboard -->
  <section class="py-10 border-t border-b border-[var(--color-border)] bg-[var(--color-bg-alt)]/20">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid md:grid-cols-2 gap-6 not-prose mb-8">
        <WordOfTheDay />
        <DailyChallenge />
      </div>
      <SmartScrabbleCoach />
    </div>
  </section>

  <!-- SEO Content Sections -->
  <section class="py-12 md:py-16">
    <div class="container mx-auto px-4 max-w-4xl prose prose-lg">
      <h2 class="text-2xl md:text-3xl font-bold mb-6">How To Use This Word Finder</h2>
      <ol class="space-y-3">
        <li>
          <strong>Enter your letters</strong> — Type the tiles on your rack into the search box. Use <code
            >?</code
          > to represent blank tiles.
        </li>
        <li>
          <strong>Choose your dictionary</strong> — Pick TWL (Tournament Word List for North American
          Scrabble), SOWPODS (international), or ENABLE (Words With Friends).
        </li>
        <li>
          <strong>Set filters</strong> — Use advanced options to filter by word length, starting or ending
          letters, or letters that must be included.
        </li>
        <li>
          <strong>Review results</strong> — Words appear grouped by length, with Scrabble tile scores.
          Click any word to see its definition.
        </li>
        <li>
          <strong>Sort as you like</strong> — Sort by highest score, word length, or alphabetically.
        </li>
      </ol>

      <h2 class="text-2xl md:text-3xl font-bold mt-12 mb-6">What is Scrabble?</h2>
      <p>
        Scrabble is a classic board game in which players use lettered tiles to create words on a
        15×15 game board. Each tile carries a point value, and the board features premium squares
        that multiply letter or word scores. The game challenges players to combine vocabulary
        knowledge with strategic tile placement to outscore opponents. First published in 1948,
        Scrabble is now played in over 120 countries and 30 languages.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold mt-12 mb-6">Tips for Scrabble</h2>
      <div class="grid md:grid-cols-2 gap-6 not-prose">
        <div class="feature-card">
          <h3 class="font-semibold text-lg mb-2">🎯 Learn Two-Letter Words</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Memorize all valid 2-letter words. They're essential for parallel plays and squeezing
            into tight board positions. <a
              href="/two-letter-scrabble-words"
              class="text-[var(--color-primary)] hover:underline">See the full list →</a
            >
          </p>
        </div>
        <div class="feature-card">
          <h3 class="font-semibold text-lg mb-2">💎 Use High-Value Tiles Wisely</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Don't waste Q, Z, X, J on low-scoring plays. Aim for premium squares and combine with
            common letters for massive points.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="font-semibold text-lg mb-2">🔗 Hook Words</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Add a single letter to an existing word (like turning "HEAT" into "CHEAT" or "HEATS") to
            score points for both words.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="font-semibold text-lg mb-2">⭐ Aim for Bingos</h3>
          <p class="text-[var(--color-text-muted)] text-sm">
            Using all 7 tiles in a single play earns a 50-point bonus. Keep a balanced rack of
            vowels and consonants to maximize bingo chances.
          </p>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold mt-12 mb-6">Popular Word Lists</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 not-prose">
        <a
          href="/two-letter-scrabble-words"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all"
        >
          <span class="text-2xl font-bold text-[var(--color-primary)]">2</span>
          <p class="text-sm font-medium mt-1">Letter Words</p>
        </a>
        <a
          href="/3-letter-words"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all"
        >
          <span class="text-2xl font-bold text-[var(--color-primary)]">3</span>
          <p class="text-sm font-medium mt-1">Letter Words</p>
        </a>
        <a
          href="/4-letter-words-starting-with/a"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all"
        >
          <span class="text-2xl font-bold text-[var(--color-primary)]">4+</span>
          <p class="text-sm font-medium mt-1">Letter Words</p>
        </a>
        <a
          href="/words-without-vowels"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all"
        >
          <span class="text-2xl">🚫</span>
          <p class="text-sm font-medium mt-1">No-Vowel Words</p>
        </a>
        <a
          href="/scrabble-vowel-words"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all"
        >
          <span class="text-2xl">🔤</span>
          <p class="text-sm font-medium mt-1">Vowel Words</p>
        </a>
        <a
          href="/word-lists"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all"
        >
          <span class="text-2xl">📚</span>
          <p class="text-sm font-medium mt-1">All Word Lists</p>
        </a>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold mt-12 mb-6">Latest Articles</h2>
      <div id="latest-articles" class="grid md:grid-cols-2 gap-6 not-prose">
        {
          latestPosts.length > 0 ? (
            latestPosts.map((post) => {
              const dateVal = post.pubDate;
              const formattedDate = new Date(dateVal).toLocaleDateString('en-US', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
              });
              return (
                <a
                  href={`/blog/${post.slug}`}
                  class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-5 hover:shadow-md transition-shadow flex flex-col justify-between group"
                >
                  <div>
                    <p class="font-semibold text-[var(--color-text-main)] group-hover:text-[var(--color-primary)] transition-colors">
                      {post.title}
                    </p>
                    <p class="text-sm text-gray-500 mt-1 line-clamp-2">{post.description}</p>
                  </div>
                  <div class="flex items-center gap-1.5 text-xs text-[var(--color-text-muted)] mt-4">
                    <svg
                      class="h-3.5 w-3.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
                      />
                    </svg>
                    <time datetime={new Date(dateVal).toISOString()}>{formattedDate}</time>
                  </div>
                </a>
              );
            })
          ) : (
            <a
              href="/blog"
              class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-5 hover:shadow-md transition-shadow"
            >
              <p class="text-[var(--color-primary)] font-semibold">Visit our Blog →</p>
              <p class="text-sm text-gray-500 mt-1">Tips, strategies, and word game guides</p>
            </a>
          )
        }
      </div>
    </div>
  </section>

  <!-- Definition Modal -->
  <div
    id="definition-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-word-title"
    aria-hidden="true"
  >
    <div
      class="bg-[var(--color-card)] rounded-2xl shadow-2xl max-w-lg w-full max-h-[80vh] overflow-y-auto"
    >
      <div class="flex items-center justify-between p-5 border-b">
        <h3 id="modal-word-title" class="text-xl font-bold uppercase tracking-wide"></h3>
        <button
          id="modal-close-btn"
          class="text-[var(--color-text-muted)] hover:text-[var(--color-text-main)] p-1"
          aria-label="Close"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path></svg
          >
        </button>
      </div>
      <div id="modal-body" class="p-5">
        <!-- Populated by JS -->
      </div>
    </div>
  </div>
</BaseLayout>
<script>
  import { initWordFinder } from '../lib/wordHelper';
  initWordFinder({ defaultDict: 'TWL' });
</script>
