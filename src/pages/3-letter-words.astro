---
import { SITE_URL } from '@lib/config';
import { TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES } from '../data/tileScores';
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import { loadDictionary } from '../lib/dictionaryLoader';
import { calculateWordScore } from '../lib/scoreCalculator';

const title = '3 Letter Scrabble Words — Complete List with Scores';
const description =
  'Browse all valid 3-letter words for Scrabble and Words With Friends. Includes point values, grouped by starting letter, with TWL, SOWPODS, and ENABLE dictionary support.';

const twlWords = [...(await loadDictionary('TWL'))].filter((w) => w.length === 3);
const sowpodsWords = [...(await loadDictionary('SOWPODS'))].filter((w) => w.length === 3);
const enableWords = [...(await loadDictionary('ENABLE'))].filter((w) => w.length === 3);

function groupByFirst(words: string[]) {
  const groups: Record<string, { word: string; score: number }[]> = {};
  words.forEach((w) => {
    const first = w[0].toUpperCase();
    if (!groups[first]) groups[first] = [];
    groups[first].push({ word: w.toUpperCase(), score: calculateWordScore(w, 'TWL') });
  });
  Object.values(groups).forEach((arr) => arr.sort((a, b) => a.word.localeCompare(b.word)));
  return groups;
}

const twlGrouped = groupByFirst(twlWords);
const sowpodsGrouped = groupByFirst(sowpodsWords);
const enableGrouped = groupByFirst(enableWords);
const allGroupedJson = JSON.stringify({
  TWL: twlGrouped,
  SOWPODS: sowpodsGrouped,
  ENABLE: enableGrouped,
});
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Word Lists', href: '/word-lists' },
  { label: '3-Letter Words' },
];
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    canonical=`${SITE_URL}/3-letter-words`
    schemaType="List"
    listItems={twlWords.slice(0, 100).map((w) => ({ name: w, url: `/word/${w.toLowerCase()}` }))}
  />

  <Breadcrumb items={breadcrumbItems} />

  <section class="py-10 md:py-16">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-3">
          3 Letter Scrabble Words
        </h1>
        <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto">
          The complete list of valid 3-letter words. Perfect for short plays, hooks, and opening up
          the board.
        </p>
        <p class="text-sm text-[var(--color-text-muted)] opacity-60 mt-2">
          TWL: {twlWords.length} words · SOWPODS: {sowpodsWords.length} words · ENABLE: {
            enableWords.length
          } words
        </p>
      </div>

      <!-- Dictionary Filter -->
      <div class="flex justify-center gap-2 mb-8">
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-primary)] text-white"
          data-dict="TWL">TWL</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)]"
          data-dict="SOWPODS">SOWPODS</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)]"
          data-dict="ENABLE">ENABLE</button
        >
      </div>

      <div class="flex gap-6">
        <!-- Alphabet Sidebar -->
        <nav
          class="hidden md:flex flex-col gap-1 sticky top-24 self-start"
          aria-label="Alphabet navigation"
        >
          {
            alphabet.map((letter) => (
              <a
                href={`#letter-${letter}`}
                class="w-8 h-8 flex items-center justify-center text-sm font-semibold rounded hover:bg-[var(--color-primary)] hover:text-white transition-colors text-[var(--color-text-muted)]"
              >
                {letter}
              </a>
            ))
          }
        </nav>

        <!-- Word Grid -->
        <div id="word-grid" class="flex-1">
          {
            alphabet.map((letter) => (
              <div id={`letter-${letter}`} class="mb-8 scroll-mt-20">
                <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                  <span class="w-9 h-9 flex items-center justify-center bg-[var(--color-primary)] text-white rounded-lg font-bold">
                    {letter}
                  </span>
                  <span>3-letter words starting with {letter}</span>
                  <span class="text-sm font-normal text-[var(--color-text-muted)] opacity-70">
                    ({(twlGrouped[letter] || []).length})
                  </span>
                </h2>
                <div
                  class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 letter-group"
                  data-letter={letter}
                >
                  {(twlGrouped[letter] || []).map(({ word, score }) => (
                    <a
                      href={`/word/${word.toLowerCase()}`}
                      class="word-card bg-[var(--color-card)] rounded-lg border border-[var(--color-border)] p-2.5 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all cursor-pointer block"
                      data-word={word}
                    >
                      <div class="flex items-center justify-center gap-0.5 mb-1">
                        {word.split('').map((ch) => (
                          <span class="tile tile-sm">
                            {ch}
                            <sub>{calculateWordScore(ch, 'TWL')}</sub>
                          </span>
                        ))}
                      </div>
                      <span class="score-badge text-xs">{score} pts</span>
                    </a>
                  ))}
                  {!(twlGrouped[letter] || []).length && (
                    <p class="text-gray-400 text-sm col-span-full">No words</p>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Mobile alphabet bar -->
      <div
        class="md:hidden fixed bottom-0 left-0 right-0 bg-[var(--color-card)] border-t border-[var(--color-border)] px-2 py-1.5 flex justify-between z-40"
      >
        {
          alphabet.map((letter) => (
            <a
              href={`#letter-${letter}`}
              class="text-[10px] font-bold text-[var(--color-text-muted)] hover:text-[var(--color-primary)]"
            >
              {letter}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 max-w-4xl">
    <AdPlaceholder slot_id="three-letter-mid" class="my-8" />
  </div>

  <section class="py-12 md:py-16 border-t">
    <div class="container mx-auto px-4 max-w-4xl prose prose-lg">
      <h2 class="text-2xl font-bold mb-4">Why Learn 3-Letter Words?</h2>
      <p>
        Three-letter words are the workhorses of Scrabble. They form the foundation for hooks —
        adding a letter to a 2-letter word to make a 3-letter one, or extending a 3-letter word with
        a prefix or suffix. With {twlWords.length} valid 3-letter words in the TWL dictionary, knowing
        even a fraction gives you a significant advantage.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4">High-Scoring 3-Letter Words</h2>
      <p>
        Some 3-letter words pack a serious scoring punch. Words like <strong>ZAX</strong> (19 pts), <strong
          >ZEK</strong
        > (16 pts), and <strong>QUA</strong> (12 pts) can turn a mediocre play into a game-changer, especially
        on premium squares.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4">Related Word Lists</h2>
      <div class="not-prose grid grid-cols-2 md:grid-cols-3 gap-4">
        <a
          href="/two-letter-scrabble-words"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all transition-shadow"
        >
          <span class="font-bold text-[var(--color-primary)]">2-Letter Words</span>
        </a>
        <a
          href="/4-letter-words-starting-with/a"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all transition-shadow"
        >
          <span class="font-bold text-[var(--color-primary)]">4-Letter Words</span>
        </a>
        <a
          href="/word-list"
          class="block bg-[var(--color-card)] rounded-xl border border-[var(--color-border)] p-4 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all transition-shadow"
        >
          <span class="font-bold text-[var(--color-primary)]">All Lists</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<div id="word-data" class="hidden" 
  data-all={allGroupedJson} 
  data-twl={JSON.stringify(TWL_SCORES)} 
  data-sowpods={JSON.stringify(SOWPODS_SCORES)} 
  data-enable={JSON.stringify(ENABLE_SCORES)}></div>

<script is:inline>
  (function () {
    const dataEl = document.getElementById('word-data');
    if (!dataEl) return;
    const allGrouped = JSON.parse(dataEl.dataset.all || '{}');
    const TILE_SCORES = {
      TWL: JSON.parse(dataEl.dataset.twl || '{}'),
      SOWPODS: JSON.parse(dataEl.dataset.sowpods || '{}'),
      ENABLE: JSON.parse(dataEl.dataset.enable || '{}'),
    };

    document.querySelectorAll('.dict-filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.dict-filter-btn').forEach((b) => {
          b.classList.remove('bg-[var(--color-primary)]', 'text-white');
          b.classList.add('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        });
        btn.classList.add('bg-[var(--color-primary)]', 'text-white');
        btn.classList.remove('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        const dict = btn.dataset.dict;
        const data = allGrouped[dict] || {};
        const scores = TILE_SCORES[dict];
        document.querySelectorAll('.letter-group').forEach((group) => {
          const letter = group.dataset.letter;
          const words = data[letter] || [];
          if (!words.length) {
            group.innerHTML =
              '<p class="text-[var(--color-text-muted)] text-sm col-span-full">No words</p>';
            return;
          }
          group.innerHTML = words
            .map(({ word }) => {
              const score = word.split('').reduce((t, c) => t + (scores[c] || 0), 0);
              return `<a href="/word/${word.toLowerCase()}" class="word-card bg-[var(--color-card)] rounded-lg border border-[var(--color-border)] p-2.5 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all cursor-pointer block"><div class="flex items-center justify-center gap-0.5 mb-1">${word
                .split('')
                .map((c) => `<span class="tile tile-sm">${c}<sub>${scores[c] || 0}</sub></span>`)
                .join('')}</div><span class="score-badge text-xs">${score} pts</span></a>`;
            })
            .join('');
        });
      });
    });
  })();
</script>
