---
import { SITE_URL } from '@lib/config';
import { TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES } from '../data/tileScores';
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import { loadDictionary } from '../lib/dictionaryLoader';
import { calculateWordScore } from '../lib/scoreCalculator';
import { getWordDetails } from '../lib/wordDetails';

const title = 'Most Common 5-Letter Words — Scrabble & Wordle Word List';
const description =
  'Complete list of the 100 most common 5-letter words in English. Perfect for Wordle strategies, Scrabble, and other word games.';

const twlAll = Array.from(await loadDictionary('TWL'));
const twlTop = twlAll
  .filter((w) => w.length === 5)
  .map((w) => {
    const details = getWordDetails(w);
    return {
      word: w.toUpperCase(),
      score: calculateWordScore(w, 'TWL'),
      freq: details.frequency.percentage,
    };
  })
  .sort((a, b) => b.freq - a.freq || a.word.localeCompare(b.word))
  .slice(0, 100);

const sowpodsAll = Array.from(await loadDictionary('SOWPODS'));
const sowpodsTop = sowpodsAll
  .filter((w) => w.length === 5)
  .map((w) => {
    const details = getWordDetails(w);
    return {
      word: w.toUpperCase(),
      score: calculateWordScore(w, 'SOWPODS'),
      freq: details.frequency.percentage,
    };
  })
  .sort((a, b) => b.freq - a.freq || a.word.localeCompare(b.word))
  .slice(0, 100);

const enableAll = Array.from(await loadDictionary('ENABLE'));
const enableTop = enableAll
  .filter((w) => w.length === 5)
  .map((w) => {
    const details = getWordDetails(w);
    return {
      word: w.toUpperCase(),
      score: calculateWordScore(w, 'ENABLE'),
      freq: details.frequency.percentage,
    };
  })
  .sort((a, b) => b.freq - a.freq || a.word.localeCompare(b.word))
  .slice(0, 100);

const allDataJson = JSON.stringify({ TWL: twlTop, SOWPODS: sowpodsTop, ENABLE: enableTop });

const faqs = [
  {
    question: 'What are the most common letters in 5-letter words?',
    answer:
      'The letters E, A, R, O, T, L, I, and S are the most frequently used letters in five-letter English words. Utilizing these letters on your early Wordle guesses increases your success rate.',
  },
  {
    question: 'What is the best starting word for Wordle?',
    answer:
      'Popular mathematically optimal starting words include CRANE, SLATE, SALET, and ADIEU, as they cover high-frequency vowels and consonants.',
  },
];
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    canonical=`${SITE_URL}/most-common-5-letter-words`
    schemaType="List"
    faqs={faqs}
  />
  <JsonLd
    slot="head"
    schema={{
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: title,
      description,
      url: `${SITE_URL}/most-common-5-letter-words`,
    }}
  />

  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: 'Word Lists', href: '/word-list' },
      { label: 'Most Common 5-Letter Words' },
    ]}
  />

  <section class="py-10 md:py-16">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <h1
          class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-3 font-['Plus_Jakarta_Sans',system-ui,sans-serif]"
        >
          Most Common 5-Letter Words
        </h1>
        <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto">
          Explore the top 100 most common five-letter words. Crucial for word-building strategies,
          crossword solving, and optimizing guesses in Wordle.
        </p>
      </div>

      <!-- Dictionary Filter -->
      <div class="flex justify-center gap-2 mb-8">
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-semibold rounded-full bg-[var(--color-primary)] text-white"
          data-dict="TWL">TWL</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-semibold rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)] transition-colors border border-[var(--color-border)]"
          data-dict="SOWPODS">SOWPODS</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-semibold rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)] transition-colors border border-[var(--color-border)]"
          data-dict="ENABLE">ENABLE</button
        >
      </div>

      <!-- Word Grid Container -->
      <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3"
        id="words-grid"
      >
        {
          twlTop.map(({ word, score }) => (
            <a
              href={`/word/${word.toLowerCase()}`}
              class="word-card bg-[var(--color-card)] rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] p-3 text-center hover:shadow-md transition-all"
            >
              <div class="flex items-center justify-center gap-0.5 mb-1.5">
                {word.split('').map((ch) => (
                  <span class="tile !w-7 !h-7 !text-xs shadow-sm">
                    {ch}
                    <sub class="!text-[0.6rem]">{calculateWordScore(ch, 'TWL')}</sub>
                  </span>
                ))}
              </div>
              <span class="score-badge text-xs">{score} pts</span>
            </a>
          ))
        }
      </div>

      <div class="prose max-w-none mt-16 text-[var(--color-text-main)]">
        <h2 class="text-2xl font-bold mb-4">5-Letter Words in Modern Word Games</h2>
        <p class="leading-relaxed mb-4">
          Five-letter words form the core of many modern puzzle formats, most notably Wordle.
          Knowing which 5-letter combinations are most common in everyday vocabulary helps you
          eliminate cold paths and focus your rack on high-probability layouts.
        </p>

        <h3 class="text-xl font-semibold mt-6 mb-3">Winning Strategy Tips</h3>
        <ul class="list-disc list-inside space-y-2 mb-4">
          <li>
            <strong>Consonant Clusters:</strong> Look for common blends like CH, SH, TH, ST, and TR at
            the start or end of your words.
          </li>
          <li>
            <strong>Vowel Rotations:</strong> Keeping track of used vowels ensures you do not waste turns
            on invalid guesses.
          </li>
          <li>
            <strong>Letter Frequency:</strong> Prioritize placing high-frequency tiles like E, A, and
            R in the central column slots.
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ allDataJson, TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES }}>
  (function () {
    const allData = JSON.parse(allDataJson);
    const TILE_SCORES = {
      TWL: TWL_SCORES,
      SOWPODS: SOWPODS_SCORES,
      ENABLE: ENABLE_SCORES,
    };

    const grid = document.getElementById('words-grid');

    function renderCard(word, score, scores) {
      return `<a href="/word/${word.toLowerCase()}" class="word-card bg-[var(--color-card)] rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] p-3 text-center hover:shadow-md transition-all">
      <div class="flex items-center justify-center gap-0.5 mb-1.5">${word
        .split('')
        .map(
          (c) =>
            `<span class="tile !w-7 !h-7 !text-xs shadow-sm">${c}<sub>${scores[c] || 0}</sub></span>`,
        )
        .join('')}</div>
      <span class="score-badge text-xs">${score} pts</span>
    </a>`;
    }

    document.querySelectorAll('.dict-filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.dict-filter-btn').forEach((b) => {
          b.classList.remove('bg-[var(--color-primary)]', 'text-white');
          b.classList.add('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        });
        btn.classList.add('bg-[var(--color-primary)]', 'text-white');
        btn.classList.remove('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        const dict = btn.dataset.dict;
        const words = allData[dict] || [];
        const scores = TILE_SCORES[dict];
        if (grid)
          grid.innerHTML = words.map(({ word, score }) => renderCard(word, score, scores)).join('');
      });
    });
  })();
</script>
