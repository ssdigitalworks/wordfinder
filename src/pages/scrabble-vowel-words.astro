---
import { SITE_URL } from '@lib/config';
import { TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES } from '../data/tileScores';
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import { loadDictionary } from '../lib/dictionaryLoader';
import { calculateWordScore } from '../lib/scoreCalculator';

const title = 'Scrabble Vowel Words — Words with Mostly or All Vowels';
const description =
  'Complete list of Scrabble words made up entirely or mostly of vowels (A, E, I, O, U). Perfect for clearing a vowel-heavy rack and scoring points.';

const vowelSet = new Set(['A', 'E', 'I', 'O', 'U']);

function vowelRatio(word: string) {
  const upper = word.toUpperCase();
  const count = upper.split('').filter((c) => vowelSet.has(c)).length;
  return count / upper.length;
}

const twlAll = [...(await loadDictionary('TWL'))];
// Words that are all vowels or ≥ 75% vowels and length >= 2
const twlVowelWords = twlAll
  .filter((w) => w.length >= 2 && vowelRatio(w) >= 0.75)
  .map((w) => ({
    word: w.toUpperCase(),
    score: calculateWordScore(w, 'TWL'),
    ratio: vowelRatio(w),
  }))
  .sort((a, b) => b.ratio - a.ratio || b.score - a.score);

const sowpodsAll = [...(await loadDictionary('SOWPODS'))];
const sowpodsVowelWords = sowpodsAll
  .filter((w) => w.length >= 2 && vowelRatio(w) >= 0.75)
  .map((w) => ({
    word: w.toUpperCase(),
    score: calculateWordScore(w, 'SOWPODS'),
    ratio: vowelRatio(w),
  }))
  .sort((a, b) => b.ratio - a.ratio || b.score - a.score);

const enableAll = [...(await loadDictionary('ENABLE'))];
const enableVowelWords = enableAll
  .filter((w) => w.length >= 2 && vowelRatio(w) >= 0.75)
  .map((w) => ({
    word: w.toUpperCase(),
    score: calculateWordScore(w, 'ENABLE'),
    ratio: vowelRatio(w),
  }))
  .sort((a, b) => b.ratio - a.ratio || b.score - a.score);

// Separate all-vowel from mostly-vowel
const allVowel = twlVowelWords.filter((w) => w.ratio === 1);
const mostlyVowel = twlVowelWords.filter((w) => w.ratio < 1);

const allDataJson = JSON.stringify({
  TWL: twlVowelWords,
  SOWPODS: sowpodsVowelWords,
  ENABLE: enableVowelWords,
});
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    canonical=`${SITE_URL}/scrabble-vowel-words`
  />
  <JsonLd
    slot="head"
    schema={{
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: title,
      description,
      url: `${SITE_URL}/scrabble-vowel-words`,
    }}
  />

  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: 'Word Lists', href: '/word-lists' },
      { label: 'Vowel Words' },
    ]}
  />

  <section class="py-10 md:py-16">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-3">
          Scrabble Vowel Words
        </h1>
        <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto">
          Words made entirely or mostly of vowels — essential for clearing a vowel-heavy rack.
        </p>
        <p class="text-sm text-[var(--color-text-muted)] opacity-60 mt-2">
          TWL: {twlVowelWords.length} words · SOWPODS: {sowpodsVowelWords.length} words · ENABLE: {
            enableVowelWords.length
          } words
        </p>
      </div>

      <!-- Dictionary Filter -->
      <div class="flex justify-center gap-2 mb-8">
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-primary)] text-white"
          data-dict="TWL">TWL</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)]"
          data-dict="SOWPODS">SOWPODS</button
        >
        <button
          class="dict-filter-btn px-4 py-2 text-sm font-medium rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-main)]"
          data-dict="ENABLE">ENABLE</button
        >
      </div>

      <!-- All Vowel Words -->
      {
        allVowel.length > 0 && (
          <div class="mb-10">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
              <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2.5 py-0.5 rounded-full">
                100% vowels
              </span>
              All-Vowel Words
            </h2>
            <div
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3"
              id="all-vowel-grid"
            >
              {allVowel.map(({ word, score }) => (
                <a
                  href={`/word/${word.toLowerCase()}`}
                  class="word-card bg-[var(--color-card)] rounded-lg border-2 border-yellow-300 p-3 text-center hover:shadow-md transition-all block"
                >
                  <div class="flex items-center justify-center gap-0.5 mb-1.5">
                    {word.split('').map((ch) => (
                      <span class="tile">
                        {ch}
                        <sub>{calculateWordScore(ch, 'TWL')}</sub>
                      </span>
                    ))}
                  </div>
                  <span class="score-badge">{score} pts</span>
                </a>
              ))}
            </div>
          </div>
        )
      }

      <!-- Mostly Vowel Words -->
      <div>
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded-full"
            >75%+ vowels</span
          >
          Mostly-Vowel Words
        </h2>
        <div
          class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3"
          id="mostly-vowel-grid"
        >
          {
            mostlyVowel.map(({ word, score }) => (
              <a
                href={`/word/${word.toLowerCase()}`}
                class="word-card bg-[var(--color-card)] rounded-lg border border-[var(--color-border)] p-3 text-center hover:shadow-md hover:border-[var(--color-primary)] transition-all block"
              >
                <div class="flex items-center justify-center gap-0.5 mb-1.5">
                  {word.split('').map((ch) => (
                    <span class="tile">
                      {ch}
                      <sub>{calculateWordScore(ch, 'TWL')}</sub>
                    </span>
                  ))}
                </div>
                <span class="score-badge">{score} pts</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 max-w-4xl">
    <AdPlaceholder slot_id="vowel-words-mid" class="my-8" />
  </div>

  <section class="py-12 md:py-16 border-t">
    <div class="container mx-auto px-4 max-w-4xl prose prose-lg">
      <h2 class="text-2xl font-bold mb-4">When Vowel Words Save the Day</h2>
      <p>
        Drawing too many vowels is a common Scrabble frustration. Instead of swapping tiles and
        losing your turn, play one of these vowel-heavy words to reduce your vowel count while still
        scoring points. Many of these words also set up good board positions for future plays.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4">Key Vowel Words to Know</h2>
      <ul>
        <li><strong>AQUAE</strong> — Plural of aqua (5 letters, all but Q are vowels)</li>
        <li><strong>OURIE</strong> — Feeling cold or chilly (5 letters, 4 vowels)</li>
        <li><strong>ADIEU</strong> — A farewell (5 letters, 4 vowels) — great for rack balance</li>
        <li><strong>AUDIO</strong> — Relating to sound (5 letters, 4 vowels)</li>
        <li><strong>AEON</strong> — A long period of time (4 letters, 3 vowels)</li>
        <li><strong>EAU</strong> — Water (in French loanwords) (3 letters, all vowels)</li>
      </ul>

      <h2 class="text-2xl font-bold mt-10 mb-4">Strategy Tip</h2>
      <p>
        If you have 5+ vowels on your rack, look for words from this list that can connect with
        existing consonants on the board. Parallel plays alongside consonant-rich words can score
        well even with vowel-heavy tiles.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ allDataJson, TWL_SCORES, ENABLE_SCORES, SOWPODS_SCORES }}>
  (function () {
    const allData = JSON.parse(allDataJson);
    const TILE_SCORES = {
      TWL: TWL_SCORES,
      SOWPODS: SOWPODS_SCORES,
      ENABLE: ENABLE_SCORES,
    };

    const allVowelGrid = document.getElementById('all-vowel-grid');
    const mostlyVowelGrid = document.getElementById('mostly-vowel-grid');

    function renderCard(word, score, scores, highlight) {
      const border = highlight
        ? 'border-2 border-yellow-300 dark:border-yellow-600'
        : 'border border-[var(--color-border)] hover:border-[var(--color-primary)]';
      return `<a href="/word/${word.toLowerCase()}" class="word-card bg-[var(--color-card)] rounded-lg ${border} p-3 text-center hover:shadow-md transition-all block">
      <div class="flex items-center justify-center gap-0.5 mb-1.5">${word
        .split('')
        .map((c) => `<span class="tile">${c}<sub>${scores[c] || 0}</sub></span>`)
        .join('')}</div>
      <span class="score-badge">${score} pts</span>
    </a>`;
    }

    document.querySelectorAll('.dict-filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.dict-filter-btn').forEach((b) => {
          b.classList.remove('bg-[var(--color-primary)]', 'text-white');
          b.classList.add('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        });
        btn.classList.add('bg-[var(--color-primary)]', 'text-white');
        btn.classList.remove('bg-[var(--color-bg-alt)]', 'text-[var(--color-text-muted)]');
        const dict = btn.dataset.dict;
        const words = allData[dict] || [];
        const scores = TILE_SCORES[dict];
        const allV = words.filter((w) => w.ratio === 1);
        const mostV = words.filter((w) => w.ratio < 1);
        if (allVowelGrid)
          allVowelGrid.innerHTML = allV
            .map(({ word, score }) => renderCard(word, score, scores, true))
            .join('');
        if (mostlyVowelGrid)
          mostlyVowelGrid.innerHTML = mostV
            .map(({ word, score }) => renderCard(word, score, scores, false))
            .join('');
      });
    });
  })();
</script>
