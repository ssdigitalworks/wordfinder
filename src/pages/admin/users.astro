---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db/client';
import { users } from '../../db/schema';
import { hasRequiredRole, getUserIdFromPayload } from '../../lib/adminAuth';

export const prerender = false;

// Authenticate user — middleware also handles this, but double-check role here
const userPayload = Astro.locals.userPayload as string | undefined;
if (!userPayload || !hasRequiredRole(userPayload, ['owner'])) {
  return Astro.redirect('/admin/login');
}

// Fetch all users — only expose safe fields, never password hash
let allUsers: { id: number; email: string; role: string; createdAt: string }[] = [];
let dbError = '';
try {
  if (db) {
    allUsers = await db.select({
      id: users.id,
      email: users.email,
      role: users.role,
      createdAt: users.createdAt,
    }).from(users).all();
  } else {
    dbError = 'Database not configured';
  }
} catch (e: unknown) {
  dbError = e instanceof Error ? e.message : 'Error fetching users';
}

// Use the auth library function, not raw string splitting
const currentUserId = getUserIdFromPayload(userPayload);
---

<AdminLayout title="Admin Users">
  <div class="max-w-4xl mx-auto space-y-8">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-extrabold text-[var(--color-text-main)] font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
        Manage Admin Users
      </h1>
    </div>

    {dbError && (
      <div class="bg-red-500/10 border border-red-500/20 text-red-600 px-4 py-3 rounded-xl text-sm font-medium">
        {dbError}
      </div>
    )}

    {/* New Admin Form */}
    <div class="card p-6 md:p-8 border border-[var(--color-border)] bg-[var(--color-card)] rounded-2xl shadow-sm space-y-6">
      <h2 class="text-xl font-bold text-[var(--color-text-main)] border-b border-[var(--color-border)] pb-3 font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
        Add New Admin
      </h2>
      <form id="new-user-form" class="space-y-4 max-w-xl">
        <div class="space-y-2">
          <label for="email" class="block text-sm font-semibold text-[var(--color-text-main)]">
            Email Address
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] text-[var(--color-text-main)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/50 focus:border-[var(--color-primary)] transition-all"
            placeholder="admin@example.com"
          />
        </div>

        <div class="space-y-2">
          <label for="password" class="block text-sm font-semibold text-[var(--color-text-main)]">
            Password
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="10"
            class="w-full px-4 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] text-[var(--color-text-main)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/50 focus:border-[var(--color-primary)] transition-all"
            placeholder="At least 10 characters"
          />
        </div>

        <div id="form-error" class="text-sm text-red-500 font-medium hidden"></div>
        <div id="form-success" class="text-sm text-green-500 font-medium hidden"></div>

        <div class="pt-2">
          <button
            type="submit"
            id="submit-btn"
            class="px-6 py-2.5 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white text-sm font-bold rounded-xl shadow-md transition-all active:scale-95 disabled:opacity-50"
          >
            Add Admin
          </button>
        </div>
      </form>
    </div>

    {/* Users List */}
    <div class="card border border-[var(--color-border)] bg-[var(--color-card)] rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="bg-[var(--color-bg-alt)]/50 border-b border-[var(--color-border)] text-[var(--color-text-muted)] font-semibold uppercase text-xs tracking-wider">
            <tr>
              <th class="px-6 py-4">ID</th>
              <th class="px-6 py-4">Email</th>
              <th class="px-6 py-4">Role</th>
              <th class="px-6 py-4">Created At</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[var(--color-border)]" id="users-table-body">
            {allUsers.length === 0 ? (
              <tr>
                <td colspan="5" class="px-6 py-8 text-center text-[var(--color-text-muted)]">
                  No users found.
                </td>
              </tr>
            ) : (
              allUsers.map((u) => (
                <tr class="hover:bg-[var(--color-bg-alt)]/50 transition-colors group">
                  <td class="px-6 py-4 whitespace-nowrap text-[var(--color-text-muted)]">#{u.id}</td>
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-[var(--color-text-main)]">
                    {u.email}
                    {u.id === currentUserId && <span class="ml-2 text-xs bg-[var(--color-primary-wash)] text-[var(--color-primary)] px-2 py-0.5 rounded-full font-bold">You</span>}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-[var(--color-text-muted)] capitalize">
                    {u.role}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-[var(--color-text-muted)] text-xs">
                    {new Date(u.createdAt).toLocaleDateString()}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right">
                    <button
                      type="button"
                      class={`delete-user-btn text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors ${
                        u.id === currentUserId 
                          ? 'bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] cursor-not-allowed opacity-50' 
                          : 'bg-red-50 text-red-600 hover:bg-red-100 hover:text-red-700'
                      }`}
                      data-id={u.id}
                      data-email={u.email}
                      disabled={u.id === currentUserId}
                    >
                      Delete
                    </button>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('new-user-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorDiv = document.getElementById('form-error') as HTMLDivElement;
  const successDiv = document.getElementById('form-success') as HTMLDivElement;

  // Read CSRF token from meta tag (set by AdminLayout)
  const csrfToken = (document.querySelector('meta[name="csrf-token"]') as HTMLMetaElement)?.content || '';

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Adding...';

      const formData = new FormData(form);
      const email = formData.get('email');
      const password = formData.get('password');

      try {
        const res = await fetch('/api/admin/users', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken,
          },
          body: JSON.stringify({ email, password }),
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Failed to add user');
        }

        successDiv.textContent = 'User added successfully! Reloading...';
        successDiv.classList.remove('hidden');
        form.reset();
        
        setTimeout(() => {
          window.location.reload();
        }, 1000);

      } catch (err: any) {
        errorDiv.textContent = err.message;
        errorDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Add Admin';
      }
    });
  }

  const deleteBtns = document.querySelectorAll('.delete-user-btn');
  deleteBtns.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      if (target.disabled) return;

      const id = target.getAttribute('data-id');
      const email = target.getAttribute('data-email');
      
      if (!confirm(`Are you sure you want to delete the admin user "${email}"? This action cannot be undone.`)) {
        return;
      }

      target.disabled = true;
      target.textContent = '...';

      try {
        const res = await fetch(`/api/admin/users/${id}`, {
          method: 'DELETE',
          headers: {
            'X-CSRF-Token': csrfToken,
          },
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Failed to delete user');
        }

        window.location.reload();

      } catch (err: any) {
        alert(err.message);
        target.disabled = false;
        target.textContent = 'Delete';
      }
    });
  });
</script>
