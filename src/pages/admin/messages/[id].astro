---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db } from '@db/client';
import { messages } from '@db/schema';
import { eq } from 'drizzle-orm';

export const prerender = false;

const { id: idParam } = Astro.params;
const id = Number(idParam);

let msg: typeof messages.$inferSelect | null = null;
let dbError = '';

if (db) {
  try {
    msg = (await db.select().from(messages).where(eq(messages.id, id)).get()) || null;
    if (!msg) {
      dbError = 'Message not found';
    } else if (!msg.read) {
      // Automatically mark message as read on page load
      await db.update(messages).set({ read: true }).where(eq(messages.id, id));
      msg.read = true; // update local representation
    }
  } catch (e: unknown) {
    dbError = e instanceof Error ? e.message : String(e) || 'Database error occurred';
    console.error('Error handling message view:', e);
  }
} else {
  dbError = 'Database not configured';
}
---

<AdminLayout title={msg ? `View: ${msg.subject}` : 'View Message'}>
  <div class="max-w-3xl mx-auto space-y-6">
    <!-- Navigation Back Link -->
    <div>
      <a
        href="/admin/messages"
        class="text-sm font-medium text-[var(--color-primary)] hover:text-[var(--color-primary-light)] flex items-center gap-1"
      >
        &larr; Back to Messages
      </a>
    </div>

    <!-- Error state -->
    {
      dbError && (
        <div class="card p-6 text-center border border-red-200 dark:border-red-900/30 bg-[var(--color-card)] rounded-2xl">
          <p class="text-lg font-medium text-red-600 dark:text-red-400">{dbError}</p>
          <a href="/admin/messages" class="btn-primary mt-4 inline-block">
            Return to Messages
          </a>
        </div>
      )
    }

    <!-- Message Detail Card -->
    {
      !dbError && msg && (
        <div class="card border border-[var(--color-border)] bg-[var(--color-card)] rounded-2xl shadow-sm overflow-hidden relative">
          <div class="absolute top-0 left-0 right-0 h-1.5 bg-[var(--color-primary)]" />

          <div class="p-6 md:p-8 space-y-6">
            {/* Metadata Header */}
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 border-b border-[var(--color-border)] pb-6">
              <div class="space-y-1">
                <h1 class="text-2xl font-bold text-[var(--color-text-main)] font-['Plus_Jakarta_Sans',system-ui,sans-serif]">
                  {msg.subject}
                </h1>
                <div class="text-sm text-[var(--color-text-muted)] space-y-1">
                  <div>
                    From: <span class="font-bold text-[var(--color-text-main)]">{msg.name}</span>
                    <a
                      href={`mailto:${msg.email}`}
                      class="text-[var(--color-primary)] hover:underline ml-1"
                    >
                      &lt;{msg.email}&gt;
                    </a>
                  </div>
                  <div class="text-xs">
                    Submitted: {msg.createdAt ? new Date(msg.createdAt).toLocaleString() : 'N/A'}
                  </div>
                </div>
              </div>

              {/* Read / Unread Status pill */}
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-400 self-start">
                Read
              </span>
            </div>

            {/* Message body */}
            <div class="text-[var(--color-text-main)] leading-relaxed text-base whitespace-pre-wrap min-h-36 bg-[var(--color-bg-alt)]/20 p-6 rounded-2xl border border-[var(--color-border)]">
              {msg.message}
            </div>

            {/* Actions */}
            <div class="flex items-center justify-between border-t border-[var(--color-border)] pt-6">
              <a
                href={`mailto:${msg.email}?subject=RE: ${encodeURIComponent(msg.subject)}`}
                class="btn-primary px-6 py-2.5 rounded-xl font-semibold inline-flex items-center gap-2"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"
                  />
                </svg>
                Reply via Email
              </a>

              <button
                type="button"
                id="delete-msg-btn"
                data-msg-id={msg.id}
                class="px-5 py-2.5 rounded-xl border border-red-200 hover:bg-red-50 dark:hover:bg-red-950/20 hover:text-red-600 dark:hover:border-red-900/30 text-red-500 text-sm font-semibold transition-colors cursor-pointer"
              >
                Delete Message
              </button>
            </div>
          </div>
        </div>
      )
    }
  </div>
</AdminLayout>

<script>
  import { showToast } from '../../../lib/toast';

  const deleteBtn = document.getElementById('delete-msg-btn');
  deleteBtn?.addEventListener('click', async () => {
    const msgId = deleteBtn.getAttribute('data-msg-id');
    if (!msgId) return;

    if (confirm('Are you sure you want to delete this message permanently?')) {
      (deleteBtn as HTMLButtonElement).disabled = true;
      deleteBtn.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/admin/messages/${msgId}`, {
          method: 'DELETE',
        });

        if (res.ok) {
          window.location.href = '/admin/messages';
        } else {
          showToast('Failed to delete message.', 'error');
          (deleteBtn as HTMLButtonElement).disabled = false;
          deleteBtn.textContent = 'Delete Message';
        }
      } catch (err) {
        console.error(err);
        showToast('A network error occurred.', 'error');
        (deleteBtn as HTMLButtonElement).disabled = false;
        deleteBtn.textContent = 'Delete Message';
      }
    }
  });
</script>
