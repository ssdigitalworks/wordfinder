---
import '../../styles/global.css';

export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FAF9F6" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex,nofollow" />

    <title>Reset Password | WordFinder Admin</title>

    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plus-jakarta-sans-700.woff2" as="font" type="font/woff2" crossorigin />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text-main)] min-h-screen flex items-center justify-center p-4 font-[var(--font-control)]">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-extrabold text-[var(--color-primary)] font-['Plus_Jakarta_Sans',system-ui,sans-serif] tracking-tight">
          WordFinder Admin
        </h1>
        <p class="text-sm text-[var(--color-text-muted)] mt-2">
          Enter your new password below
        </p>
      </div>

      <div class="card p-8 border border-[var(--color-border)] shadow-xl relative overflow-hidden bg-[var(--color-card)] rounded-2xl">
        <div class="absolute top-0 left-0 right-0 h-1.5 bg-[var(--color-primary)]"></div>

        <form id="reset-form" class="space-y-6">
          <input type="hidden" id="token" name="token" value="" />

          <div>
            <label for="newPassword" class="block text-sm font-semibold text-[var(--color-text-main)] mb-2">
              New Password
            </label>
            <div class="relative mb-4">
              <input
                type="password"
                id="newPassword"
                name="newPassword"
                required
                minlength="6"
                placeholder="Must be at least 6 characters"
                class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] text-[var(--color-text-main)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/50 focus:border-[var(--color-primary)] transition-all placeholder-[var(--color-text-muted)]/50"
              />
            </div>
            
            <label for="confirmPassword" class="block text-sm font-semibold text-[var(--color-text-main)] mb-2">
              Confirm Password
            </label>
            <div class="relative">
              <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                required
                minlength="6"
                placeholder="Re-enter new password"
                class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] text-[var(--color-text-main)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/50 focus:border-[var(--color-primary)] transition-all placeholder-[var(--color-text-muted)]/50"
              />
            </div>
          </div>

          <div id="status-alert" class="hidden p-4 rounded-xl text-sm font-medium"></div>

          <button type="submit" id="submit-btn" class="w-full btn-primary py-3 rounded-xl font-bold flex items-center justify-center gap-2 cursor-pointer">
            Reset Password
          </button>
        </form>
      </div>
    </div>

    <script>
      // Extract token from URL
      const urlParams = new URLSearchParams(window.location.search);
      const token = urlParams.get('token');
      const tokenInput = document.getElementById('token') as HTMLInputElement;
      
      if (token && tokenInput) {
        tokenInput.value = token;
      } else {
        const statusAlert = document.getElementById('status-alert') as HTMLDivElement;
        statusAlert.innerText = 'Invalid link. No token found in URL.';
        statusAlert.className = 'p-4 rounded-xl text-sm font-medium bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900/30 text-red-600 dark:text-red-400 block';
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
        submitBtn.disabled = true;
      }

      const form = document.getElementById('reset-form') as HTMLFormElement;
      const statusAlert = document.getElementById('status-alert') as HTMLDivElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const tokenVal = formData.get('token');
        const newPassword = formData.get('newPassword') as string;
        const confirmPassword = formData.get('confirmPassword') as string;

        if (newPassword !== confirmPassword) {
          statusAlert.innerText = 'Passwords do not match.';
          statusAlert.className = 'p-4 rounded-xl text-sm font-medium bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900/30 text-red-600 dark:text-red-400 block';
          return;
        }

        statusAlert.classList.add('hidden');
        statusAlert.innerText = '';
        submitBtn.disabled = true;
        submitBtn.innerText = 'Resetting...';

        try {
          const res = await fetch('/api/admin/reset-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token: tokenVal, newPassword }),
          });

          const data = await res.json();

          if (res.ok && data.success) {
            statusAlert.innerText = 'Password reset successful! Redirecting to login...';
            statusAlert.className = 'p-4 rounded-xl text-sm font-medium bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-900/30 text-green-700 dark:text-green-400 block';
            form.reset();
            setTimeout(() => {
              window.location.href = '/admin/login';
            }, 2000);
          } else {
            statusAlert.innerText = data.error || 'Failed to reset password.';
            statusAlert.className = 'p-4 rounded-xl text-sm font-medium bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900/30 text-red-600 dark:text-red-400 block';
            submitBtn.disabled = false;
            submitBtn.innerText = 'Reset Password';
          }
        } catch (err) {
          console.error('Reset error:', err);
          statusAlert.innerText = 'A network error occurred. Please try again.';
          statusAlert.className = 'p-4 rounded-xl text-sm font-medium bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900/30 text-red-600 dark:text-red-400 block';
          submitBtn.disabled = false;
          submitBtn.innerText = 'Reset Password';
        }
      });
    </script>
  </body>
</html>
