---
import { SITE_URL } from '@lib/config';
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import SEO from '@components/seo/SEO.astro';
import Breadcrumb from '@components/layout/Breadcrumb.astro';

const lastUpdated = 'June 20, 2026';
const title = 'Legal Disclaimer — Scrabble Word Finder';
const description =
  'Trademark and legal disclaimer for Scrabble Word Finder. Learn about our relationship with Hasbro, Mattel, Zynga, and other word game trademark holders.';
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
---

<BaseLayout>
  <SEO slot="head" title={title} description={description} canonical={canonical} />

  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Legal Disclaimer' }]} />

  <section class="max-w-4xl mx-auto px-4 py-12">
    <!-- Page Header -->
    <div class="mb-10">
      <h1
        class="text-4xl md:text-5xl font-extrabold text-[var(--color-text-main)] mb-4 font-['Plus_Jakarta_Sans',system-ui,sans-serif] animate-entrance"
      >
        Legal &amp; Trademark Disclaimer
      </h1>
      <p class="text-sm text-[var(--color-text-muted)] animate-entrance delay-1">
        Last Updated: {lastUpdated}
      </p>
    </div>

    <!-- Content -->
    <div class="card p-8 md:p-10 animate-entrance delay-2">
      <div
        class="prose-content
        [&>p]:text-base [&>p]:leading-relaxed [&>p]:text-[var(--color-text-main)] [&>p]:mb-5
        [&>h2]:font-['Plus_Jakarta_Sans',system-ui,sans-serif] [&>h2]:text-xl [&>h2]:font-bold [&>h2]:text-[var(--color-text-main)] [&>h2]:mt-8 [&>h2]:mb-3
        [&>h3]:font-['Plus_Jakarta_Sans',system-ui,sans-serif] [&>h3]:text-lg [&>h3]:font-bold [&>h3]:text-[var(--color-text-main)] [&>h3]:mt-6 [&>h3]:mb-2
        [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-5 [&>ul]:space-y-1.5 [&>ul]:text-[var(--color-text-main)]
        [&>a]:text-[var(--color-primary)] [&>a]:underline [&>a]:hover:opacity-80 [&>a]:transition-opacity"
      >
        <p>
          Please read this legal and trademark disclaimer carefully before using
          ScrabbleWordFinder.com (the "Website").
        </p>

        <h2>1. Trademark Clearances</h2>
        <p>
          <strong
            >ScrabbleWordFinder.com is an independent word helper and educational website and is NOT
            associated with, authorized by, sponsored by, or endorsed by Hasbro, Inc., Mattel Inc.,
            Zynga Inc., or any of their affiliates or subsidiaries.</strong
          >
        </p>
        <p>
          All trademarks, registered trademarks, game names, product names, logos, or service marks
          mentioned on this Website are the property of their respective owners:
        </p>
        <ul>
          <li>
            <strong>SCRABBLE®</strong> is a registered trademark of Hasbro, Inc. in the United States
            and Canada, and J.W. Spear &amp; Sons PLC (a subsidiary of Mattel, Inc.) throughout the rest
            of the world.
          </li>
          <li>
            <strong>Words With Friends™</strong> and <strong>Words With Friends 2™</strong> are trademarks
            of Zynga Inc.
          </li>
          <li><strong>Wordle™</strong> is a trademark of The New York Times Company.</li>
        </ul>
        <p>
          Use of these trademarks on our Website is strictly for nominative, educational, and
          descriptive purposes to identify the games and help users find valid words. No affiliation
          or commercial endorsement is implied.
        </p>

        <h2>2. Use of Word Lists and Validity</h2>
        <p>
          While we compile our data from recognized word databases (like TWL, SOWPODS, and ENABLE)
          to provide the highest accuracy, we cannot guarantee that the words generated by our
          lookup engine are acceptable in official tournaments or local game matches. All data is
          provided "as is" and for casual entertainment/educational purposes only.
        </p>

        <h2>3. Limitation of Liability</h2>
        <p>
          In no event shall ScrabbleWordFinder.com, its developers, or its owners be liable for any
          damages (including, without limitation, direct, indirect, incidental, special,
          consequential, or punitive damages) arising out of your access to, use of, or inability to
          use this Website, its calculators, or its solvers.
        </p>

        <h2>4. External Links Disclaimer</h2>
        <p>
          Our Website may contain links to third-party websites for convenience and informational
          purposes. These links do not constitute an endorsement of, or responsibility for, the
          content, products, services, or privacy practices of those third-party sites. We have no
          control over the content of linked sites and accept no responsibility for them or for any
          loss or damage that may arise from your use of them.
        </p>

        <h2>5. No Warranty</h2>
        <p>
          THIS WEBSITE AND ALL CONTENT, TOOLS, AND SERVICES ARE PROVIDED ON AN "AS IS" AND "AS
          AVAILABLE" BASIS WITHOUT ANY WARRANTY OF ANY KIND, EITHER EXPRESS OR IMPLIED, INCLUDING
          BUT NOT LIMITED TO WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE,
          ACCURACY, OR NON-INFRINGEMENT. WE DO NOT WARRANT THAT THE SERVICE WILL BE UNINTERRUPTED,
          ERROR-FREE, OR THAT DEFECTS WILL BE CORRECTED.
        </p>

        <h2>6. Word Validity Disclaimer</h2>
        <p>
          The word lists provided on this site are compiled from publicly available word databases
          (TWL, SOWPODS, ENABLE) and are intended for entertainment and educational purposes only.
          We make no guarantee that any word found or validated by our tools will be accepted in any
          official Scrabble tournament, club game, or competition. Always refer to the official
          rules and word lists of the governing body of your game for tournament play.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
