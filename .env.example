# -----------------------------------------------------------------------------
# Scrabble Word Finder — Environment Variables
#
# LOCAL DEV:  Copy this file to '.env' and fill in your values.
# VERCEL:     Set all of these in the Vercel dashboard under
#             Project Settings → Environment Variables.
#             Do NOT rely on .env files in Vercel deployments.
# -----------------------------------------------------------------------------

# [SECRET] Resend API Key for sending email via the contact form
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# [SECRET] The destination email address to receive contact form submissions
CONTACT_EMAIL=hello@scrabblewordfinder.com

# [SECRET] The verified sender email address for the contact form
CONTACT_FROM_EMAIL=Contact Form <contact@scrabblewordfinder.com>

# [PUBLIC] Google AdSense Publisher Client ID
# Prefix with 'PUBLIC_' to expose it safely to the browser/client layout.
PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# [PUBLIC] Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_MEASUREMENT_ID=

# [PUBLIC] Custom Webhook/Endpoint for Client-side Error Reporting (Optional)
# If left blank, it defaults to '/api/log-error' which logs to server logs.
PUBLIC_ERROR_REPORTING_URL=

# [SECRET] Upstash Redis REST API configuration for serverless rate limiting
# Get from: https://console.upstash.com → Create Database → REST API
# REQUIRED for production on Vercel — without this, rate limiting is unreliable.
KV_REST_API_URL=https://your-upstash-redis-url.upstash.io
KV_REST_API_TOKEN=your_upstash_redis_token_here

# [SECRET] Turso database credentials for content and settings storage
# LOCAL:   TURSO_DATABASE_URL=file:local.db  (SQLite file on disk)
# VERCEL:  TURSO_DATABASE_URL=libsql://your-db-name.turso.io  (remote Turso DB)
# Get from: https://turso.tech → Create Database → Get connection string
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# [SECRET] Admin Panel Session Secret
# Generate a 64-character random hex string. Example:
#   node -e "require('crypto').randomBytes(32).toString('hex').then(console.log)" 
#   OR: openssl rand -hex 32
ADMIN_SESSION_SECRET=YOUR_RANDOM_64_CHAR_HEX_STRING_HERE

# [SECRET] Admin Panel Hashed Password
# Run: node scripts/hash-admin-password.js
# Then paste the output hash value here.
ADMIN_PASSWORD_HASH=YOUR_HASHED_PASSWORD_HERE

# [SECRET] Feature Flag for initial admin account creation
# Set to 'true' ONLY when first bootstrapping (no users in DB yet).
# IMPORTANT: Set to 'false' or remove after first successful login!
ALLOW_ADMIN_BOOTSTRAP=true

